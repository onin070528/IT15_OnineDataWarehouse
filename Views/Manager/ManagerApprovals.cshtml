@using it15_webproject_mvc.Models
@using System.Text.Json
@{
    var pending = ViewData["PendingSubmissions"] as List<DataSubmission> ?? new List<DataSubmission>();
    var recent = ViewData["RecentDecisions"] as List<DataSubmission> ?? new List<DataSubmission>();
    var previewData = ViewData["PreviewData"] as Dictionary<int, (List<string> Columns, List<Dictionary<string, string>> Rows)>
                      ?? new Dictionary<int, (List<string> Columns, List<Dictionary<string, string>> Rows)>();
    var pendingCount = (int)(ViewData["PendingCount"] ?? 0);
    var approvedCount = (int)(ViewData["ApprovedCount"] ?? 0);
    var rejectedCount = (int)(ViewData["RejectedCount"] ?? 0);
}

<div class="p-8 min-h-full" style="background-color: #EBF4F6;">

    @if (TempData["Success"] != null)
    {
        <div id="successToast" class="mb-6 flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-lg shadow-sm">
            <span class="w-5 h-5 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center text-xs flex-shrink-0">?</span>
            <span class="text-sm font-medium">@TempData["Success"]</span>
            <button onclick="document.getElementById('successToast').remove()" class="ml-auto text-emerald-400 hover:text-emerald-600">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div id="errorToast" class="mb-6 flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg shadow-sm">
            <span class="w-5 h-5 rounded-full bg-red-100 text-red-600 flex items-center justify-center text-xs flex-shrink-0">?</span>
            <span class="text-sm font-medium">@TempData["Error"]</span>
            <button onclick="document.getElementById('errorToast').remove()" class="ml-auto text-red-400 hover:text-red-600">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
    }

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-8">
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold" style="color: #088395;">@pendingCount</p>
                    <p class="text-xs text-gray-400">Pending Review</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #09637E;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold" style="color: #09637E;">@approvedCount</p>
                    <p class="text-xs text-gray-400">Approved</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #7AB2B2;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-red-500">@rejectedCount</p>
                    <p class="text-xs text-gray-400">Rejected</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Pending Submissions -->
    <div class="bg-white rounded-2xl shadow-sm p-8 mb-8" style="border: 1px solid #7AB2B2;">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">Pending Approvals</h3>
                <p class="text-sm text-gray-500">Submissions waiting for your review — approve or reject each one</p>
            </div>
        </div>

        @if (pending.Any())
        {
            <div class="space-y-4">
                @foreach (var sub in pending)
                {
                    var hasPreview = previewData.ContainsKey(sub.SubmissionID);
                    var previewId = $"preview-{sub.SubmissionID}";

                    <div class="border rounded-xl overflow-hidden transition-all" style="border-color: #7AB2B2;">
                        <div class="p-6">
                            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
                                <div class="flex-1">
                                    <div class="flex items-center gap-3 mb-2">
                                        <span class="text-xs font-mono font-semibold text-gray-800 bg-gray-100 px-2 py-0.5 rounded">@sub.BatchId</span>
                                        <span class="text-xs font-medium px-2 py-0.5 rounded-full text-amber-600 bg-amber-50">Pending</span>
                                    </div>
                                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
                                        <div>
                                            <p class="text-xs text-gray-400">Source</p>
                                            <p class="font-semibold text-gray-800">@(sub.DataSource?.SourceName ?? "—")</p>
                                        </div>
                                        <div>
                                            <p class="text-xs text-gray-400">Target Table</p>
                                            <p class="font-mono text-xs text-gray-600">@sub.TargetTable</p>
                                        </div>
                                        <div>
                                            <p class="text-xs text-gray-400">Rows (Valid / Total)</p>
                                            <p class="text-gray-800"><span class="text-green-600 font-bold">@sub.ValidRows</span> / @sub.TotalRows
                                                @if (sub.ErrorRows > 0)
                                                {
                                                    <span class="text-red-500 text-xs">(@sub.ErrorRows errors)</span>
                                                }
                                            </p>
                                        </div>
                                        <div>
                                            <p class="text-xs text-gray-400">Submitted By</p>
                                            <p class="text-gray-600">@(sub.SubmittedByUser?.Full_name ?? "—")</p>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(sub.Notes))
                                    {
                                        <div class="mt-3 bg-gray-50 rounded-lg px-3 py-2">
                                            <p class="text-xs text-gray-400 mb-0.5">Notes</p>
                                            <p class="text-xs text-gray-600">@sub.Notes</p>
                                        </div>
                                    }
                                </div>
                                <div class="flex items-center gap-2 flex-shrink-0">
                                    @if (hasPreview)
                                    {
                                        <button onclick="var el = document.getElementById('@previewId'); el.classList.toggle('hidden'); this.querySelector('span').textContent = el.classList.contains('hidden') ? 'Preview Data' : 'Hide Data';"
                                                class="px-4 py-2.5 text-sm font-semibold rounded-lg border transition-colors" style="border-color: #7AB2B2; color: #088395;" onmouseover="this.style.backgroundColor='#EBF4F6'" onmouseout="this.style.backgroundColor=''">
                                            <span>Preview Data</span>
                                        </button>
                                    }
                                    <form method="post" action="@Url.Action("ApproveSubmission", "Manager")">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="submissionId" value="@sub.SubmissionID" />
                                        <button type="submit"
                                                class="px-5 py-2.5 bg-green-600 text-white text-sm font-semibold rounded-lg hover:bg-green-700 transition-colors">
                                            ? Approve
                                        </button>
                                    </form>
                                    <form method="post" action="@Url.Action("RejectSubmission", "Manager")">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="submissionId" value="@sub.SubmissionID" />
                                        <button type="submit"
                                                class="px-5 py-2.5 bg-red-500 text-white text-sm font-semibold rounded-lg hover:bg-red-600 transition-colors">
                                            ? Reject
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>

                        @if (hasPreview)
                        {
                            var (columns, rows) = previewData[sub.SubmissionID];
                            <div id="@previewId" class="hidden border-t" style="border-color: #7AB2B2;">
                                <div class="px-6 py-3" style="background-color: #EBF4F6;">
                                    <div class="flex items-center justify-between">
                                        <p class="text-xs font-semibold" style="color: #09637E;">
                                            <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                                            Data Preview — @rows.Count row(s) shown (max 20)
                                        </p>
                                        <div class="flex items-center gap-3 text-xs">
                                            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-green-500"></span> Valid</span>
                                            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-yellow-400"></span> Warning</span>
                                            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-red-500"></span> Error</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="overflow-x-auto max-h-96 overflow-y-auto">
                                    <table class="w-full text-xs">
                                        <thead class="sticky top-0 bg-white">
                                            <tr class="border-b border-gray-200">
                                                <th class="text-left py-2 px-3 font-semibold text-gray-500">#</th>
                                                <th class="text-center py-2 px-3 font-semibold text-gray-500">Status</th>
                                                @foreach (var col in columns)
                                                {
                                                    <th class="text-left py-2 px-3 font-semibold" style="color: #088395;">@col</th>
                                                }
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{ var rowNum = 1; }
                                            @foreach (var row in rows)
                                            {
                                                var status = row.ContainsKey("_status") ? row["_status"] : "Pending";
                                                var statusColor = status == "Valid" ? "text-green-600 bg-green-50" :
                                                                  status == "Warning" ? "text-yellow-600 bg-yellow-50" :
                                                                  status == "Error" ? "text-red-600 bg-red-50" : "text-gray-500 bg-gray-100";
                                                var rowBg = status == "Error" ? "bg-red-50/30" : status == "Warning" ? "bg-yellow-50/30" : "";

                                                <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors @rowBg" title="@(row.ContainsKey("_message") && row["_message"] != "" ? row["_message"] : "")">
                                                    <td class="py-2 px-3 text-gray-400 font-mono">@rowNum</td>
                                                    <td class="py-2 px-3 text-center">
                                                        <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded-full @statusColor">@status</span>
                                                    </td>
                                                    @foreach (var col in columns)
                                                    {
                                                        var cellValue = row.ContainsKey(col) ? row[col] : "";
                                                        <td class="py-2 px-3 text-gray-700">
                                                            <div style="max-height:2rem; overflow:hidden; resize:vertical; min-height:1.5rem;" title="@cellValue">@cellValue</div>
                                                        </td>
                                                    }
                                                </tr>
                                                rowNum++;
                                            }
                                        </tbody>
                                    </table>
                                </div>
                                @if (rows.Count >= 20)
                                {
                                    <div class="px-6 py-2 text-center border-t" style="border-color: #EBF4F6;">
                                        <p class="text-[10px] text-gray-400">Showing first 20 rows. Full batch contains @sub.TotalRows rows.</p>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-12 text-gray-400">
                <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-sm font-medium">No pending submissions</p>
                <p class="text-xs mt-1">All submissions have been reviewed. New ones will appear here automatically.</p>
            </div>
        }
    </div>

    <!-- Recent Decisions -->
    <div class="bg-white rounded-2xl shadow-sm p-8" style="border: 1px solid #7AB2B2;">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #09637E;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">Recent Decisions</h3>
                <p class="text-sm text-gray-500">Previously approved or rejected submissions</p>
            </div>
        </div>

        @if (recent.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200">
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Batch ID</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Source</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Target</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Rows</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Date</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Decision</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sub in recent)
                        {
                            var decisionColor = sub.Status == "Integrated" ? "text-green-600 bg-green-50" : "text-red-600 bg-red-50";
                            var decisionLabel = sub.Status == "Integrated" ? "Approved" : "Rejected";
                            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                                <td class="py-3 px-4 font-mono text-xs font-semibold text-gray-800">@sub.BatchId</td>
                                <td class="py-3 px-4 text-gray-600">@(sub.DataSource?.SourceName ?? "—")</td>
                                <td class="py-3 px-4 font-mono text-xs text-gray-500">@sub.TargetTable</td>
                                <td class="py-3 px-4 text-gray-600">@sub.ValidRows/@sub.TotalRows</td>
                                <td class="py-3 px-4 text-gray-500 text-xs">@sub.Created_at.ToString("MMM dd, yyyy")</td>
                                <td class="py-3 px-4 text-center"><span class="text-xs font-semibold px-2.5 py-1 rounded-full @decisionColor">@decisionLabel</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-sm text-gray-400 text-center py-6">No decisions made yet.</p>
        }
    </div>
</div>
