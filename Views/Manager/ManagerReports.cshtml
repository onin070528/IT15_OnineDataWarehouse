@{
    var sourceSummary = ViewData["SourceSummary"] as dynamic;
    var statusBreakdown = ViewData["StatusBreakdown"] as dynamic;
    var monthlySubmissions = ViewData["MonthlySubmissions"] as dynamic;
}

<div class="p-8 min-h-full" style="background-color: #EBF4F6;">

    <!-- Submission Status Breakdown -->
    <div class="bg-white rounded-2xl shadow-sm p-8 mb-8" style="border: 1px solid #7AB2B2;">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">Submission Status Report</h3>
                <p class="text-sm text-gray-500">Breakdown of all data submissions by current status</p>
            </div>
        </div>
        @if (statusBreakdown != null && ((System.Collections.ICollection)statusBreakdown!).Count > 0)
        {
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                @foreach (var item in (IEnumerable<dynamic>)statusBreakdown!)
                {
                    var color = (string)item.Status switch {
                        "Integrated" => "border-green-400 bg-green-50 text-green-700",
                        "Submitted" => "border-amber-400 bg-amber-50 text-amber-700",
                        "Failed" => "border-red-400 bg-red-50 text-red-700",
                        "Verified" => "border-blue-400 bg-blue-50 text-blue-700",
                        _ => "border-gray-300 bg-gray-50 text-gray-700"
                    };
                    <div class="border-2 rounded-xl p-5 @color">
                        <p class="text-2xl font-bold">@item.Count</p>
                        <p class="text-sm font-semibold mt-1">@item.Status</p>
                        <p class="text-xs opacity-70 mt-1">@(((int)item.Rows).ToString("N0")) total rows</p>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-sm text-gray-400 text-center py-6">No submission data available for reporting.</p>
        }
    </div>

    <!-- Monthly Submission Report -->
    <div class="bg-white rounded-2xl shadow-sm p-8 mb-8" style="border: 1px solid #7AB2B2;">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #09637E;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">Monthly Submission Trend</h3>
                <p class="text-sm text-gray-500">Submissions per month (last 12 months)</p>
            </div>
        </div>
        @if (monthlySubmissions != null && ((System.Collections.ICollection)monthlySubmissions!).Count > 0)
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200">
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Month</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Submissions</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Total Rows</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Volume</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int maxRows = 1;
                            foreach (var m in (IEnumerable<dynamic>)monthlySubmissions!)
                            {
                                if ((int)m.Rows > maxRows) maxRows = (int)m.Rows;
                            }
                        }
                        @foreach (var m in (IEnumerable<dynamic>)monthlySubmissions!)
                        {
                            var monthName = new DateTime((int)m.Year, (int)m.Month, 1).ToString("MMM yyyy");
                            var pct = maxRows > 0 ? (int)m.Rows * 100 / maxRows : 0;
                            <tr class="border-b border-gray-100 hover:bg-gray-50">
                                <td class="py-3 px-4 font-semibold text-gray-800">@monthName</td>
                                <td class="py-3 px-4 text-gray-600">@m.Count</td>
                                <td class="py-3 px-4 text-gray-600">@(((int)m.Rows).ToString("N0"))</td>
                                <td class="py-3 px-4 w-1/3">
                                    <div class="w-full bg-gray-100 rounded-full h-2">
                                        <div class="h-2 rounded-full" style="width: @(pct)%; background-color: #088395;"></div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-sm text-gray-400 text-center py-6">No monthly data available.</p>
        }
    </div>

    <!-- Source Summary Report -->
    <div class="bg-white rounded-2xl shadow-sm p-8" style="border: 1px solid #7AB2B2;">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #7AB2B2;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">Source Summary Report</h3>
                <p class="text-sm text-gray-500">Data volume per configured source</p>
            </div>
        </div>
        @if (sourceSummary != null && ((System.Collections.ICollection)sourceSummary!).Count > 0)
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200">
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Source</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Target Table</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Batches</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Total Rows</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Last Sync</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in (IEnumerable<dynamic>)sourceSummary!)
                        {
                            var statusColor = (string)s.Status == "Active" ? "text-green-600 bg-green-50" :
                                              (string)s.Status == "Error" ? "text-red-600 bg-red-50" : "text-gray-500 bg-gray-100";
                            <tr class="border-b border-gray-100 hover:bg-gray-50">
                                <td class="py-3 px-4 font-semibold text-gray-800">@s.SourceName</td>
                                <td class="py-3 px-4 font-mono text-xs text-gray-500">@s.TargetTable</td>
                                <td class="py-3 px-4 text-gray-600">@s.BatchCount</td>
                                <td class="py-3 px-4 text-gray-600">@(((int)s.TotalRows).ToString("N0"))</td>
                                <td class="py-3 px-4 text-gray-500 text-xs">@(s.Last_sync != null ? ((DateTime)s.Last_sync).ToString("MMM dd, yyyy") : "Never")</td>
                                <td class="py-3 px-4 text-center"><span class="text-xs font-medium px-2.5 py-1 rounded-full @statusColor">@s.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-sm text-gray-400 text-center py-6">No sources configured yet.</p>
        }
    </div>
</div>
