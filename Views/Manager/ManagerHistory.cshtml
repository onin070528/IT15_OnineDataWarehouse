@using it15_webproject_mvc.Models
@{
    var logs = ViewData["AuditLogs"] as List<AuditLog> ?? new List<AuditLog>();
    var totalActions = (int)(ViewData["TotalActions"] ?? 0);
    var todayActions = (int)(ViewData["TodayActions"] ?? 0);
    var totalDatasets = (int)(ViewData["TotalDatasets"] ?? 0);
    var totalRecordsStored = (int)(ViewData["TotalRecordsStored"] ?? 0);
    var uniqueEntities = (int)(ViewData["UniqueEntities"] ?? 0);
    var uniqueUsers = (int)(ViewData["UniqueUsers"] ?? 0);

    var versionHistory = ViewData["VersionHistory"] as dynamic;
    var datasetSnapshots = ViewData["DatasetSnapshots"] as dynamic;
    var pipelineLifecycle = ViewData["PipelineLifecycle"] as List<DataSubmission> ?? new List<DataSubmission>();
    var monthlyActivity = ViewData["MonthlyActivity"] as dynamic;
    var monthlyRecordsPulled = ViewData["MonthlyRecordsPulled"] as dynamic;
    var monthlySourcesAdded = ViewData["MonthlySourcesAdded"] as dynamic;
    var entityTypes = ViewData["EntityTypes"] as dynamic;
}

<div class="p-8 min-h-full" style="background-color: #EBF4F6;">

    <!-- ???????????????????????????????????????????????????????????????????? -->
    <!-- TOP SUMMARY CARDS                                                   -->
    <!-- ???????????????????????????????????????????????????????????????????? -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-900">@totalActions.ToString("N0")</p>
                    <p class="text-xs text-gray-400">Total Historical Actions</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #09637E;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-900">@totalDatasets</p>
                    <p class="text-xs text-gray-400">Total Datasets</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #7AB2B2;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-900">@totalRecordsStored.ToString("N0")</p>
                    <p class="text-xs text-gray-400">Total Records Stored</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-900">@uniqueUsers</p>
                    <p class="text-xs text-gray-400">Active Contributors</p>
                </div>
            </div>
        </div>
    </div>

    <!-- ???????????????????????????????????????????????????????????????????? -->
    <!-- TIME-BASED FILTERING BAR                                            -->
    <!-- ???????????????????????????????????????????????????????????????????? -->
    <div class="bg-white rounded-2xl shadow-sm p-5 mb-8 flex flex-wrap items-center gap-4" style="border: 1px solid #7AB2B2;">
        <div class="flex items-center gap-2">
            <svg class="w-5 h-5" style="color: #088395;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
            </svg>
            <span class="text-sm font-semibold" style="color: #09637E;">Time Filter:</span>
        </div>
        <div class="flex gap-2">
            <button onclick="filterByTime('today')" id="btn-today" class="time-filter-btn px-4 py-2 text-xs font-semibold rounded-lg border transition-colors" style="border-color: #7AB2B2; color: #088395;">Today</button>
            <button onclick="filterByTime('7days')" id="btn-7days" class="time-filter-btn px-4 py-2 text-xs font-semibold rounded-lg border transition-colors" style="border-color: #7AB2B2; color: #088395;">Last 7 Days</button>
            <button onclick="filterByTime('30days')" id="btn-30days" class="time-filter-btn px-4 py-2 text-xs font-semibold rounded-lg border transition-colors" style="border-color: #7AB2B2; color: #088395;">Last 30 Days</button>
            <button onclick="filterByTime('all')" id="btn-all" class="time-filter-btn px-4 py-2 text-xs font-semibold rounded-lg border transition-colors" style="border-color: #088395; background-color: #088395; color: white;">All Time</button>
        </div>
        <div class="flex items-center gap-2 ml-auto">
            <label class="text-xs text-gray-500">Custom:</label>
            <input type="date" id="filter-start" class="text-xs border rounded-lg px-3 py-2" style="border-color: #7AB2B2;" />
            <span class="text-xs text-gray-400">to</span>
            <input type="date" id="filter-end" class="text-xs border rounded-lg px-3 py-2" style="border-color: #7AB2B2;" />
            <button onclick="filterByCustomDate()" class="px-3 py-2 text-xs font-semibold rounded-lg text-white" style="background-color: #088395;">Apply</button>
        </div>
        <div class="flex items-center gap-2">
            <label class="text-xs text-gray-500">Entity:</label>
            <select id="entity-filter" onchange="filterByEntity()" class="text-xs border rounded-lg px-3 py-2" style="border-color: #7AB2B2;">
                <option value="all">All Entities</option>
                @if (entityTypes != null)
                {
                    @foreach (var et in (IEnumerable<dynamic>)entityTypes!)
                    {
                        <option value="@et.EntityType">@et.EntityType (@et.Count)</option>
                    }
                }
            </select>
        </div>
    </div>

    <!-- ???????????????????????????????????????????????????????????????????? -->
    <!-- HISTORICAL TREND CHARTS                                             -->
    <!-- ???????????????????????????????????????????????????????????????????? -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 mb-8">
        <!-- Records Pulled Over Time -->
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/>
                    </svg>
                </div>
                <h4 class="text-sm font-bold" style="color: #09637E;">Records Pulled Over Time</h4>
            </div>
            <div class="space-y-2">
                @if (monthlyRecordsPulled != null && ((System.Collections.ICollection)monthlyRecordsPulled!).Count > 0)
                {
                    int maxRecPulled = 1;
                    foreach (var m in (IEnumerable<dynamic>)monthlyRecordsPulled!) { if ((int)m.Count > maxRecPulled) maxRecPulled = (int)m.Count; }
                    foreach (var m in (IEnumerable<dynamic>)monthlyRecordsPulled!)
                    {
                        var label = new DateTime((int)m.Year, (int)m.Month, 1).ToString("MMM yyyy");
                        var pct = maxRecPulled > 0 ? (int)m.Count * 100 / maxRecPulled : 0;
                        <div class="flex items-center gap-3">
                            <span class="text-xs text-gray-500 w-16 flex-shrink-0">@label</span>
                            <div class="flex-1 bg-gray-100 rounded-full h-3 relative">
                                <div class="h-3 rounded-full" style="width: @(pct)%; background: linear-gradient(90deg, #088395, #7AB2B2);"></div>
                            </div>
                            <span class="text-xs font-semibold text-gray-600 w-12 text-right">@(((int)m.Count).ToString("N0"))</span>
                        </div>
                    }
                }
                else
                {
                    <p class="text-xs text-gray-400 text-center py-8">No data yet</p>
                }
            </div>
        </div>

        <!-- Sources Added Over Time -->
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #09637E;">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                    </svg>
                </div>
                <h4 class="text-sm font-bold" style="color: #09637E;">Sources Added Over Time</h4>
            </div>
            <div class="space-y-2">
                @if (monthlySourcesAdded != null && ((System.Collections.ICollection)monthlySourcesAdded!).Count > 0)
                {
                    int maxSrcAdded = 1;
                    foreach (var m in (IEnumerable<dynamic>)monthlySourcesAdded!) { if ((int)m.Count > maxSrcAdded) maxSrcAdded = (int)m.Count; }
                    foreach (var m in (IEnumerable<dynamic>)monthlySourcesAdded!)
                    {
                        var label = new DateTime((int)m.Year, (int)m.Month, 1).ToString("MMM yyyy");
                        var pct = maxSrcAdded > 0 ? (int)m.Count * 100 / maxSrcAdded : 0;
                        <div class="flex items-center gap-3">
                            <span class="text-xs text-gray-500 w-16 flex-shrink-0">@label</span>
                            <div class="flex-1 bg-gray-100 rounded-full h-3 relative">
                                <div class="h-3 rounded-full" style="width: @(pct)%; background: linear-gradient(90deg, #09637E, #088395);"></div>
                            </div>
                            <span class="text-xs font-semibold text-gray-600 w-12 text-right">@m.Count</span>
                        </div>
                    }
                }
                else
                {
                    <p class="text-xs text-gray-400 text-center py-8">No data yet</p>
                }
            </div>
        </div>

        <!-- ETL Activity Over Time -->
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #7AB2B2;">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                    </svg>
                </div>
                <h4 class="text-sm font-bold" style="color: #09637E;">ETL Activity Over Time</h4>
            </div>
            <div class="space-y-2">
                @if (monthlyActivity != null && ((System.Collections.ICollection)monthlyActivity!).Count > 0)
                {
                    int maxAct = 1;
                    foreach (var m in (IEnumerable<dynamic>)monthlyActivity!) { if ((int)m.Count > maxAct) maxAct = (int)m.Count; }
                    foreach (var m in (IEnumerable<dynamic>)monthlyActivity!)
                    {
                        var label = new DateTime((int)m.Year, (int)m.Month, 1).ToString("MMM yyyy");
                        var pct = maxAct > 0 ? (int)m.Count * 100 / maxAct : 0;
                        <div class="flex items-center gap-3">
                            <span class="text-xs text-gray-500 w-16 flex-shrink-0">@label</span>
                            <div class="flex-1 bg-gray-100 rounded-full h-3 relative">
                                <div class="h-3 rounded-full" style="width: @(pct)%; background: linear-gradient(90deg, #7AB2B2, #EBF4F6);"></div>
                            </div>
                            <span class="text-xs font-semibold text-gray-600 w-12 text-right">@m.Count</span>
                        </div>
                    }
                }
                else
                {
                    <p class="text-xs text-gray-400 text-center py-8">No data yet</p>
                }
            </div>
        </div>
    </div>

    <!-- ???????????????????????????????????????????????????????????????????? -->
    <!-- DATA VERSION HISTORY                                                -->
    <!-- ???????????????????????????????????????????????????????????????????? -->
    <div class="bg-white rounded-2xl shadow-sm p-8 mb-8" style="border: 1px solid #7AB2B2;">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">Data Version History</h3>
                <p class="text-sm text-gray-500">Track how datasets have changed over time with version control</p>
            </div>
        </div>
        @if (versionHistory != null && ((System.Collections.ICollection)versionHistory!).Count > 0)
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200">
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Dataset / Target Table</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Data Source</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Latest Version</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Total Versions</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Active Records</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Archived</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Last Updated</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Updated By</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in (IEnumerable<dynamic>)versionHistory!)
                        {
                            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                                <td class="py-3 px-4">
                                    <span class="font-semibold text-gray-800 font-mono text-xs px-2 py-1 rounded" style="background-color: #EBF4F6;">@v.TargetTable</span>
                                </td>
                                <td class="py-3 px-4 text-gray-600 text-sm">@v.DataSourceName</td>
                                <td class="py-3 px-4 text-center">
                                    <span class="inline-flex items-center justify-center w-8 h-8 rounded-full text-xs font-bold text-white" style="background-color: #088395;">v@(v.LatestVersion)</span>
                                </td>
                                <td class="py-3 px-4 text-center text-gray-600 font-semibold">@v.TotalVersions</td>
                                <td class="py-3 px-4 text-center">
                                    <span class="text-green-600 font-semibold">@(((int)v.ActiveRecords).ToString("N0"))</span>
                                </td>
                                <td class="py-3 px-4 text-center">
                                    <span class="text-gray-400 font-semibold">@(((int)v.ArchivedRecords).ToString("N0"))</span>
                                </td>
                                <td class="py-3 px-4 text-gray-500 text-xs">@(((DateTime)v.LastUpdated).ToString("MMM dd, yyyy hh:mm tt"))</td>
                                <td class="py-3 px-4">
                                    <div class="flex items-center gap-2">
                                        <span class="inline-flex items-center justify-center w-6 h-6 rounded-full text-white text-xs font-bold flex-shrink-0" style="background-color: #09637E;">
                                            @(((string)v.LastUpdatedBy).Substring(0, Math.Min(2, ((string)v.LastUpdatedBy).Length)).ToUpper())
                                        </span>
                                        <span class="text-xs text-gray-700">@v.LastUpdatedBy</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-10 text-gray-400">
                <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                </svg>
                <p class="text-sm font-medium">No version history available yet</p>
                <p class="text-xs mt-1">Data versions will appear here once records are loaded into the warehouse.</p>
            </div>
        }
    </div>

    <!-- ???????????????????????????????????????????????????????????????????? -->
    <!-- DATASET SNAPSHOTS                                                   -->
    <!-- ???????????????????????????????????????????????????????????????????? -->
    <div class="bg-white rounded-2xl shadow-sm p-8 mb-8" style="border: 1px solid #7AB2B2;">
        <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #09637E;">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                        <path d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold" style="color: #09637E;">Historical Dataset Snapshots</h3>
                    <p class="text-sm text-gray-500">Integrated dataset snapshots at specific timestamps</p>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-xs px-3 py-1.5 rounded-full font-semibold" style="background-color: #EBF4F6; color: #088395;">
                    Integrated Only
                </span>
            </div>
        </div>
        @if (datasetSnapshots != null && ((System.Collections.ICollection)datasetSnapshots!).Count > 0)
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200">
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Batch ID</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Source</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Target Table</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Records Loaded</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Skipped</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Load Mode</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Snapshot Date</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Submitted By</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var snap in (IEnumerable<dynamic>)datasetSnapshots!)
                        {
                            var modeColor = (string)snap.LoadMode switch {
                                "Append" => "text-blue-600 bg-blue-50",
                                "Overwrite" => "text-amber-600 bg-amber-50",
                                "Upsert" => "text-purple-600 bg-purple-50",
                                _ => "text-gray-600 bg-gray-50"
                            };
                            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors snapshot-row" data-date="@(snap.Integrated_at != null ? ((DateTime)snap.Integrated_at).ToString("yyyy-MM-dd") : "")">
                                <td class="py-3 px-4">
                                    <span class="font-mono text-xs font-semibold" style="color: #088395;">@snap.BatchId</span>
                                </td>
                                <td class="py-3 px-4 text-gray-700 text-sm font-medium">@snap.SourceName</td>
                                <td class="py-3 px-4">
                                    <span class="font-mono text-xs px-2 py-0.5 rounded bg-gray-100 text-gray-600">@snap.TargetTable</span>
                                </td>
                                <td class="py-3 px-4 text-center">
                                    <span class="text-green-600 font-bold">@(((int)snap.LoadedRows).ToString("N0"))</span>
                                    <span class="text-gray-400 text-xs">/ @(((int)snap.TotalRows).ToString("N0"))</span>
                                </td>
                                <td class="py-3 px-4 text-center text-red-400 text-xs">@snap.SkippedRows</td>
                                <td class="py-3 px-4 text-center">
                                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full @modeColor">@snap.LoadMode</span>
                                </td>
                                <td class="py-3 px-4 text-gray-500 text-xs whitespace-nowrap">
                                    @(snap.Integrated_at != null ? ((DateTime)snap.Integrated_at).ToString("MMM dd, yyyy") : "—")
                                    <br /><span class="text-gray-400">@(snap.Integrated_at != null ? ((DateTime)snap.Integrated_at).ToString("hh:mm tt") : "")</span>
                                </td>
                                <td class="py-3 px-4 text-sm text-gray-700">@snap.SubmittedBy</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-10 text-gray-400">
                <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                    <path d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <p class="text-sm font-medium">No dataset snapshots available</p>
                <p class="text-xs mt-1">Snapshots are created when submissions are approved and loaded.</p>
            </div>
        }
    </div>

    <!-- ???????????????????????????????????????????????????????????????????? -->
    <!-- DATA COMPARISON TOOL                                                -->
    <!-- ???????????????????????????????????????????????????????????????????? -->
    <div class="bg-white rounded-2xl shadow-sm p-8 mb-8" style="border: 1px solid #7AB2B2;">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #7AB2B2;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">Data Comparison Tool</h3>
                <p class="text-sm text-gray-500">Compare two dataset snapshots to identify changes between versions</p>
            </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div>
                <label class="text-xs font-semibold text-gray-500 block mb-2">Snapshot A (Older)</label>
                <select id="compare-snapshot-a" class="w-full text-sm border rounded-lg px-4 py-2.5" style="border-color: #7AB2B2;" onchange="compareSnapshots()">
                    <option value="">Select a snapshot...</option>
                    @if (datasetSnapshots != null)
                    {
                        @foreach (var snap in (IEnumerable<dynamic>)datasetSnapshots!)
                        {
                            <option value="@snap.SubmissionID" data-loaded="@snap.LoadedRows" data-skipped="@snap.SkippedRows" data-total="@snap.TotalRows" data-mode="@snap.LoadMode" data-source="@snap.SourceName" data-table="@snap.TargetTable" data-date="@(snap.Integrated_at != null ? ((DateTime)snap.Integrated_at).ToString("MMM dd, yyyy hh:mm tt") : "N/A")">
                                @snap.BatchId — @snap.SourceName (@(snap.Integrated_at != null ? ((DateTime)snap.Integrated_at).ToString("MMM dd") : "N/A"))
                            </option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="text-xs font-semibold text-gray-500 block mb-2">Snapshot B (Newer)</label>
                <select id="compare-snapshot-b" class="w-full text-sm border rounded-lg px-4 py-2.5" style="border-color: #7AB2B2;" onchange="compareSnapshots()">
                    <option value="">Select a snapshot...</option>
                    @if (datasetSnapshots != null)
                    {
                        @foreach (var snap in (IEnumerable<dynamic>)datasetSnapshots!)
                        {
                            <option value="@snap.SubmissionID" data-loaded="@snap.LoadedRows" data-skipped="@snap.SkippedRows" data-total="@snap.TotalRows" data-mode="@snap.LoadMode" data-source="@snap.SourceName" data-table="@snap.TargetTable" data-date="@(snap.Integrated_at != null ? ((DateTime)snap.Integrated_at).ToString("MMM dd, yyyy hh:mm tt") : "N/A")">
                                @snap.BatchId — @snap.SourceName (@(snap.Integrated_at != null ? ((DateTime)snap.Integrated_at).ToString("MMM dd") : "N/A"))
                            </option>
                        }
                    }
                </select>
            </div>
        </div>
        <!-- Comparison Result -->
        <div id="comparison-result" class="hidden">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="rounded-xl p-5 border-2 border-dashed" style="border-color: #7AB2B2; background-color: #f0fafa;">
                    <h4 class="text-xs font-bold text-gray-500 uppercase mb-3">Snapshot A</h4>
                    <div id="comp-a-details" class="space-y-2 text-sm"></div>
                </div>
                <div class="rounded-xl p-5 border-2 border-dashed" style="border-color: #088395; background-color: #f0fafa;">
                    <h4 class="text-xs font-bold text-gray-500 uppercase mb-3">Snapshot B</h4>
                    <div id="comp-b-details" class="space-y-2 text-sm"></div>
                </div>
            </div>
            <div class="mt-5 rounded-xl p-5" style="background-color: #EBF4F6;">
                <h4 class="text-xs font-bold uppercase mb-3" style="color: #09637E;">Differences</h4>
                <div id="comp-diff" class="space-y-2 text-sm"></div>
            </div>
        </div>
        <div id="comparison-empty" class="text-center py-6 text-gray-400">
            <p class="text-sm">Select two snapshots above to compare their data</p>
        </div>
    </div>

    <!-- ???????????????????????????????????????????????????????????????????? -->
    <!-- ETL PIPELINE LIFECYCLE TRACKING                                     -->
    <!-- ???????????????????????????????????????????????????????????????????? -->
    <div class="bg-white rounded-2xl shadow-sm p-8 mb-8" style="border: 1px solid #7AB2B2;">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">ETL Pipeline Lifecycle Tracking</h3>
                <p class="text-sm text-gray-500">Full lifecycle of recent data processing pipelines</p>
            </div>
        </div>
        @if (pipelineLifecycle.Any())
        {
            <div class="space-y-6">
                @foreach (var sub in pipelineLifecycle)
                {
                    var steps = new List<(string Name, string Icon, bool Done, string Time)>
                    {
                        ("Source Added", "+", true, sub.DataSource?.Created_at.ToString("MMM dd, hh:mm tt") ?? "—"),
                        ("Connection Tested", "~", sub.DataSource?.Last_sync != null, sub.DataSource?.Last_sync?.ToString("MMM dd, hh:mm tt") ?? "—"),
                        ("Data Pulled", "v", true, sub.Created_at.ToString("MMM dd, hh:mm tt")),
                        ("Batch Validated", "ok", sub.Status != "Pending", sub.Created_at.ToString("MMM dd, hh:mm tt")),
                        ("Submission Approved", ">>", sub.Status == "Integrated" || sub.Status == "Failed", sub.Submitted_at?.ToString("MMM dd, hh:mm tt") ?? "—"),
                        ("Data Loaded", "db", sub.Status == "Integrated", sub.Integrated_at?.ToString("MMM dd, hh:mm tt") ?? "—")
                    };

                    var statusBadge = sub.Status switch {
                        "Integrated" => "text-green-600 bg-green-50 border-green-200",
                        "Submitted" => "text-amber-600 bg-amber-50 border-amber-200",
                        "Failed" => "text-red-600 bg-red-50 border-red-200",
                        "Verified" => "text-blue-600 bg-blue-50 border-blue-200",
                        _ => "text-gray-600 bg-gray-50 border-gray-200"
                    };

                    <div class="rounded-xl border p-5" style="border-color: #e5e7eb;">
                        <div class="flex items-center justify-between mb-4">
                            <div class="flex items-center gap-3">
                                <span class="font-mono text-sm font-bold" style="color: #088395;">@sub.BatchId</span>
                                <span class="text-xs text-gray-400">@sub.DataSource?.SourceName &rarr; @sub.TargetTable</span>
                            </div>
                            <span class="text-xs font-semibold px-3 py-1 rounded-full border @statusBadge">@sub.Status</span>
                        </div>
                        <div class="flex items-center gap-0">
                            @for (int i = 0; i < steps.Count; i++)
                            {
                                var step = steps[i];
                                var dotColor = step.Done ? "background-color: #088395;" : "background-color: #d1d5db;";
                                var textColor = step.Done ? "color: #09637E;" : "color: #9ca3af;";
                                var lineColor = step.Done ? "background-color: #088395;" : "background-color: #e5e7eb;";

                                <div class="flex flex-col items-center flex-1">
                                    <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-bold" style="@dotColor">
                                        @(step.Done ? "?" : (i + 1).ToString())
                                    </div>
                                    <p class="text-xs font-semibold mt-1.5 text-center" style="@textColor">@step.Name</p>
                                    <p class="text-xs text-gray-400 mt-0.5">@step.Time</p>
                                </div>
                                @if (i < steps.Count - 1)
                                {
                                    <div class="h-0.5 flex-1 -mt-6 mx-0" style="@lineColor"></div>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-10 text-gray-400">
                <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                </svg>
                <p class="text-sm font-medium">No pipeline data available</p>
                <p class="text-xs mt-1">ETL pipeline lifecycle data will appear as submissions are processed.</p>
            </div>
        }
    </div>

    <!-- ???????????????????????????????????????????????????????????????????? -->
    <!-- HISTORICAL DATA EXPORT                                              -->
    <!-- ???????????????????????????????????????????????????????????????????? -->
    <div class="bg-white rounded-2xl shadow-sm p-6 mb-8" style="border: 1px solid #7AB2B2;">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold" style="color: #09637E;">Historical Data Export</h3>
                    <p class="text-sm text-gray-500">Export audit logs and historical reports</p>
                </div>
            </div>
            <div class="flex gap-3">
                <button onclick="exportAuditLog('csv')" class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold text-white transition-colors" style="background-color: #088395;">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 10v6m0 0l-3-3m3 3l3-3"/>
                    </svg>
                    CSV
                </button>
                <button onclick="exportAuditLog('excel')" class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold text-white transition-colors" style="background-color: #09637E;">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 10v6m0 0l-3-3m3 3l3-3"/>
                    </svg>
                    Excel
                </button>
                <button onclick="exportAuditLog('pdf')" class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold border transition-colors" style="border-color: #7AB2B2; color: #088395;">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 10v6m0 0l-3-3m3 3l3-3"/>
                    </svg>
                    PDF
                </button>
            </div>
        </div>
    </div>

    <!-- ???????????????????????????????????????????????????????????????????? -->
    <!-- COMPLETE AUDIT TRAIL                                                -->
    <!-- ???????????????????????????????????????????????????????????????????? -->
    <div class="bg-white rounded-2xl shadow-sm p-8" style="border: 1px solid #7AB2B2;">
        <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold" style="color: #09637E;">Complete Audit Trail</h3>
                    <p class="text-sm text-gray-500">Full history of all warehouse actions (most recent first)</p>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <input type="text" id="audit-search" placeholder="Search logs..." oninput="searchAuditLogs()"
                       class="text-sm border rounded-lg px-4 py-2" style="border-color: #7AB2B2;" />
            </div>
        </div>

        @if (logs.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm" id="audit-table">
                    <thead>
                        <tr class="border-b border-gray-200">
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Date &amp; Time</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">User</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Action</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Entity</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Name / ID</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in logs)
                        {
                            var actionColor = log.Action switch
                            {
                                "Source Added" => "text-purple-600 bg-purple-50",
                                "Source Deleted" => "text-red-600 bg-red-50",
                                "Connection Tested" => "text-sky-600 bg-sky-50",
                                "Data Pulled" => "text-emerald-600 bg-emerald-50",
                                "Batch Validated" => "text-blue-600 bg-blue-50",
                                "Batch Submitted" => "text-indigo-600 bg-indigo-50",
                                "Submission Approved" or "Submission Approved & Loaded" => "text-green-600 bg-green-50",
                                "Submission Rejected" => "text-red-600 bg-red-50",
                                _ => "text-gray-600 bg-gray-50"
                            };

                            var actionIcon = log.Action switch
                            {
                                "Source Added" => "+",
                                "Source Deleted" => "x",
                                "Connection Tested" => "~",
                                "Data Pulled" => "v",
                                "Batch Validated" => "ok",
                                "Batch Submitted" => ">>",
                                "Submission Approved" or "Submission Approved & Loaded" => "Y",
                                "Submission Rejected" => "N",
                                _ => "-"
                            };

                            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors audit-row"
                                data-date="@log.Performed_at.ToString("yyyy-MM-dd")"
                                data-entity="@log.EntityType">
                                <td class="py-3 px-4 text-gray-500 text-xs whitespace-nowrap">
                                    @log.Performed_at.ToString("MMM dd, yyyy")<br />
                                    <span class="text-gray-400">@log.Performed_at.ToString("hh:mm:ss tt")</span>
                                </td>
                                <td class="py-3 px-4">
                                    <div class="flex items-center gap-2">
                                        <span class="inline-flex items-center justify-center w-7 h-7 rounded-full text-white text-xs font-bold flex-shrink-0" style="background-color: #088395;">
                                            @(log.PerformedByUser?.Full_name?.Substring(0, Math.Min(2, log.PerformedByUser?.Full_name?.Length ?? 0)).ToUpper() ?? "??")
                                        </span>
                                        <span class="text-sm font-medium text-gray-700">@(log.PerformedByUser?.Full_name ?? "Unknown")</span>
                                    </div>
                                </td>
                                <td class="py-3 px-4 text-center">
                                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full @actionColor">@actionIcon @log.Action</span>
                                </td>
                                <td class="py-3 px-4 text-gray-500 text-xs">
                                    <span class="px-2 py-0.5 rounded bg-gray-100 font-mono">@log.EntityType</span>
                                </td>
                                <td class="py-3 px-4 text-gray-800 text-xs font-semibold">
                                    @(log.EntityName ?? "—")
                                    @if (log.EntityId.HasValue)
                                    {
                                        <span class="text-gray-400 font-normal ml-1">#@log.EntityId</span>
                                    }
                                </td>
                                <td class="py-3 px-4 text-xs text-gray-500 max-w-xs">
                                    <span class="truncate block max-w-[300px]" title="@log.Details">@(log.Details ?? "—")</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (logs.Count >= 100)
            {
                <div class="text-center mt-6">
                    <p class="text-xs text-gray-400">Showing the most recent 100 entries out of @totalActions.ToString("N0") total.</p>
                </div>
            }
        }
        else
        {
            <div class="text-center py-12 text-gray-400">
                <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-sm font-medium">No historical data recorded yet</p>
                <p class="text-xs mt-1">Actions performed across the warehouse will appear here automatically.</p>
            </div>
        }
    </div>
</div>

<!-- ???????????????????????????????????????????????????????????????????????? -->
<!-- CLIENT-SIDE SCRIPTS                                                     -->
<!-- ???????????????????????????????????????????????????????????????????????? -->
<script>
    // Time-Based Filtering
    function filterByTime(range) {
        document.querySelectorAll('.time-filter-btn').forEach(btn => {
            btn.style.backgroundColor = 'transparent';
            btn.style.color = '#088395';
        });
        const activeBtn = document.getElementById('btn-' + range);
        if (activeBtn) {
            activeBtn.style.backgroundColor = '#088395';
            activeBtn.style.color = 'white';
        }

        const now = new Date();
        let startDate = null;
        if (range === 'today') {
            startDate = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        } else if (range === '7days') {
            startDate = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
        } else if (range === '30days') {
            startDate = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);
        }

        filterRows(startDate, null);
    }

    function filterByCustomDate() {
        const startVal = document.getElementById('filter-start').value;
        const endVal = document.getElementById('filter-end').value;
        const startDate = startVal ? new Date(startVal) : null;
        const endDate = endVal ? new Date(endVal + 'T23:59:59') : null;

        document.querySelectorAll('.time-filter-btn').forEach(btn => {
            btn.style.backgroundColor = 'transparent';
            btn.style.color = '#088395';
        });

        filterRows(startDate, endDate);
    }

    function filterRows(startDate, endDate) {
        document.querySelectorAll('.audit-row').forEach(row => {
            const dateStr = row.getAttribute('data-date');
            if (!dateStr) { row.style.display = ''; return; }
            const rowDate = new Date(dateStr);
            let show = true;
            if (startDate && rowDate < startDate) show = false;
            if (endDate && rowDate > endDate) show = false;
            row.style.display = show ? '' : 'none';
        });
        document.querySelectorAll('.snapshot-row').forEach(row => {
            const dateStr = row.getAttribute('data-date');
            if (!dateStr) { row.style.display = ''; return; }
            const rowDate = new Date(dateStr);
            let show = true;
            if (startDate && rowDate < startDate) show = false;
            if (endDate && rowDate > endDate) show = false;
            row.style.display = show ? '' : 'none';
        });
    }

    // Entity-Based Filtering
    function filterByEntity() {
        const selected = document.getElementById('entity-filter').value;
        document.querySelectorAll('.audit-row').forEach(row => {
            if (selected === 'all') {
                row.style.display = '';
            } else {
                row.style.display = row.getAttribute('data-entity') === selected ? '' : 'none';
            }
        });
    }

    // Audit Log Search
    function searchAuditLogs() {
        const query = document.getElementById('audit-search').value.toLowerCase();
        document.querySelectorAll('.audit-row').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(query) ? '' : 'none';
        });
    }

    // Data Comparison Tool
    function compareSnapshots() {
        const selA = document.getElementById('compare-snapshot-a');
        const selB = document.getElementById('compare-snapshot-b');
        const resultDiv = document.getElementById('comparison-result');
        const emptyDiv = document.getElementById('comparison-empty');

        if (!selA.value || !selB.value) {
            resultDiv.classList.add('hidden');
            emptyDiv.classList.remove('hidden');
            return;
        }

        const optA = selA.options[selA.selectedIndex];
        const optB = selB.options[selB.selectedIndex];

        const dataA = {
            source: optA.dataset.source, table: optA.dataset.table,
            loaded: parseInt(optA.dataset.loaded), skipped: parseInt(optA.dataset.skipped),
            total: parseInt(optA.dataset.total), mode: optA.dataset.mode, date: optA.dataset.date
        };
        const dataB = {
            source: optB.dataset.source, table: optB.dataset.table,
            loaded: parseInt(optB.dataset.loaded), skipped: parseInt(optB.dataset.skipped),
            total: parseInt(optB.dataset.total), mode: optB.dataset.mode, date: optB.dataset.date
        };

        function buildDetail(data) {
            return '<div class="flex justify-between"><span class="text-gray-500">Source:</span><span class="font-semibold text-gray-800">' + data.source + '</span></div>' +
                '<div class="flex justify-between"><span class="text-gray-500">Target Table:</span><span class="font-mono text-xs text-gray-800">' + data.table + '</span></div>' +
                '<div class="flex justify-between"><span class="text-gray-500">Records Loaded:</span><span class="font-bold" style="color: #088395;">' + data.loaded.toLocaleString() + '</span></div>' +
                '<div class="flex justify-between"><span class="text-gray-500">Skipped:</span><span class="text-red-400">' + data.skipped + '</span></div>' +
                '<div class="flex justify-between"><span class="text-gray-500">Total Rows:</span><span class="font-semibold">' + data.total.toLocaleString() + '</span></div>' +
                '<div class="flex justify-between"><span class="text-gray-500">Load Mode:</span><span class="font-semibold">' + data.mode + '</span></div>' +
                '<div class="flex justify-between"><span class="text-gray-500">Snapshot Date:</span><span class="text-xs">' + data.date + '</span></div>';
        }

        document.getElementById('comp-a-details').innerHTML = buildDetail(dataA);
        document.getElementById('comp-b-details').innerHTML = buildDetail(dataB);

        // Build diff
        var diffHtml = '';
        var recordDiff = dataB.loaded - dataA.loaded;
        var recordDiffColor = recordDiff > 0 ? 'text-green-600' : recordDiff < 0 ? 'text-red-600' : 'text-gray-500';
        var recordDiffSign = recordDiff > 0 ? '+' : '';
        diffHtml += '<div class="flex justify-between items-center p-2 rounded bg-white"><span class="text-gray-600">Records Loaded Change:</span><span class="font-bold ' + recordDiffColor + '">' + recordDiffSign + recordDiff.toLocaleString() + '</span></div>';

        var skipDiff = dataB.skipped - dataA.skipped;
        var skipDiffColor = skipDiff > 0 ? 'text-red-500' : skipDiff < 0 ? 'text-green-600' : 'text-gray-500';
        var skipDiffSign = skipDiff > 0 ? '+' : '';
        diffHtml += '<div class="flex justify-between items-center p-2 rounded bg-white"><span class="text-gray-600">Skipped Records Change:</span><span class="font-bold ' + skipDiffColor + '">' + skipDiffSign + skipDiff + '</span></div>';

        if (dataA.mode !== dataB.mode) {
            diffHtml += '<div class="flex justify-between items-center p-2 rounded bg-white"><span class="text-gray-600">Load Mode Changed:</span><span class="font-semibold text-amber-600">' + dataA.mode + ' &rarr; ' + dataB.mode + '</span></div>';
        }
        if (dataA.source !== dataB.source) {
            diffHtml += '<div class="flex justify-between items-center p-2 rounded bg-white"><span class="text-gray-600">Source Changed:</span><span class="font-semibold text-amber-600">' + dataA.source + ' &rarr; ' + dataB.source + '</span></div>';
        }
        if (dataA.table !== dataB.table) {
            diffHtml += '<div class="flex justify-between items-center p-2 rounded bg-white"><span class="text-gray-600">Target Table Changed:</span><span class="font-semibold text-amber-600">' + dataA.table + ' &rarr; ' + dataB.table + '</span></div>';
        }

        var totalDiff = dataB.total - dataA.total;
        var totalDiffColor = totalDiff > 0 ? 'text-blue-600' : totalDiff < 0 ? 'text-red-600' : 'text-gray-500';
        var totalDiffSign = totalDiff > 0 ? '+' : '';
        diffHtml += '<div class="flex justify-between items-center p-2 rounded bg-white"><span class="text-gray-600">Total Rows Change:</span><span class="font-bold ' + totalDiffColor + '">' + totalDiffSign + totalDiff.toLocaleString() + '</span></div>';

        document.getElementById('comp-diff').innerHTML = diffHtml;

        resultDiv.classList.remove('hidden');
        emptyDiv.classList.add('hidden');
    }

    // Historical Data Export
    function exportAuditLog(format) {
        var rows = document.querySelectorAll('.audit-row');
        var data = [];
        rows.forEach(function(row) {
            if (row.style.display === 'none') return;
            var cells = row.querySelectorAll('td');
            data.push({
                DateTime: (cells[0] && cells[0].textContent || '').trim().replace(/\s+/g, ' '),
                User: (cells[1] && cells[1].textContent || '').trim(),
                Action: (cells[2] && cells[2].textContent || '').trim(),
                Entity: (cells[3] && cells[3].textContent || '').trim(),
                NameID: (cells[4] && cells[4].textContent || '').trim(),
                Details: (cells[5] && cells[5].textContent || '').trim()
            });
        });

        if (data.length === 0) {
            alert('No visible audit log entries to export.');
            return;
        }

        if (format === 'csv' || format === 'excel') {
            var headers = ['Date & Time', 'User', 'Action', 'Entity', 'Name / ID', 'Details'];
            var csv = headers.join(',') + '\n';
            data.forEach(function(row) {
                csv += [row.DateTime, row.User, row.Action, row.Entity, row.NameID, row.Details]
                    .map(function(val) { return '"' + (val || '').replace(/"/g, '""') + '"'; })
                    .join(',') + '\n';
            });

            var ext = format === 'excel' ? 'xls' : 'csv';
            var mimeType = format === 'excel' ? 'application/vnd.ms-excel' : 'text/csv';
            var blob = new Blob([csv], { type: mimeType + ';charset=utf-8;' });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url;
            a.download = 'historical_audit_log.' + ext;
            a.click();
            URL.revokeObjectURL(url);
        } else if (format === 'pdf') {
            var printContent = '<html><head><title>Historical Audit Log</title>' +
                '<style>body{font-family:Arial,sans-serif;font-size:11px;margin:20px;}' +
                'h1{color:#09637E;font-size:18px;}table{width:100%;border-collapse:collapse;margin-top:15px;}' +
                'th{background:#088395;color:white;padding:8px;text-align:left;font-size:11px;}' +
                'td{padding:6px 8px;border-bottom:1px solid #e5e7eb;font-size:10px;}' +
                'tr:nth-child(even){background:#f9fafb;}</style></head>' +
                '<body><h1>Historical Data Management - Audit Log</h1>' +
                '<p style="color:#666;font-size:10px;">Exported on ' + new Date().toLocaleString() + '</p>' +
                '<table><thead><tr><th>Date &amp; Time</th><th>User</th><th>Action</th><th>Entity</th><th>Name/ID</th><th>Details</th></tr></thead><tbody>';
            data.forEach(function(r) {
                printContent += '<tr><td>' + r.DateTime + '</td><td>' + r.User + '</td><td>' + r.Action + '</td><td>' + r.Entity + '</td><td>' + r.NameID + '</td><td>' + r.Details + '</td></tr>';
            });
            printContent += '</tbody></table></body></html>';
            var w = window.open('', '_blank');
            w.document.write(printContent);
            w.document.close();
            w.print();
        }
    }
</script>
