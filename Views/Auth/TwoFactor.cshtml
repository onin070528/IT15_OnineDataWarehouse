@{
    ViewData["Title"] = "Two-Factor Verification";
    var token = (ViewData["Token"] as string) ?? string.Empty;
    var error = (ViewData["Error"] as string) ?? string.Empty;
    string? ErrorMessage = null;

    if (!string.IsNullOrWhiteSpace(error))
    {
        if (string.Equals(error, "missing", StringComparison.OrdinalIgnoreCase))
            ErrorMessage = "Enter the verification code.";
        else if (string.Equals(error, "invalid_code", StringComparison.OrdinalIgnoreCase))
            ErrorMessage = "The verification code is invalid.";
        else if (string.Equals(error, "expired", StringComparison.OrdinalIgnoreCase))
            ErrorMessage = "The verification code has expired. Please sign in again.";
        else if (string.Equals(error, "invalid", StringComparison.OrdinalIgnoreCase))
            ErrorMessage = "The verification request is invalid. Please sign in again.";
        else
            ErrorMessage = error;
    }
}

<div class="min-h-screen flex items-center justify-center bg-white p-8">
    <div class="w-full max-w-md">
        <div class="mb-8 text-center">
            <h2 class="text-2xl font-bold text-gray-900">Verify your login</h2>
            <p class="text-sm text-gray-500 mt-2">We sent a 6-digit code to your email.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 shadow-sm">
                <span class="text-lg">&#9888;</span>
                <div>@ErrorMessage</div>
            </div>
        }

        @if (string.IsNullOrWhiteSpace(token))
        {
            <div class="bg-amber-50 border border-amber-200 text-amber-700 px-4 py-3 rounded-lg mb-6">
                Verification session is missing. Please sign in again.
            </div>
            <div class="text-center">
                <a href="@Url.Action("Login", "Home")" class="text-[#088395] hover:underline">Back to login</a>
            </div>
        }
        else
        {
            <form method="post" action="/auth/two-factor" class="space-y-6">
                @Html.AntiForgeryToken()
                <input type="hidden" name="token" value="@token" />

                <div>
                    <label for="twoFactorCode" class="block text-sm font-medium text-gray-700 mb-2">Verification Code</label>
                    <input id="twoFactorCode"
                           name="code"
                           class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-4 focus:ring-[#088395]/20 focus:border-[#088395] transition"
                           placeholder="Enter the 6-digit code"
                           inputmode="numeric"
                           maxlength="6"
                           required />
                </div>

                <button type="submit"
                        class="w-full py-3 rounded-lg bg-gradient-to-r from-[#7AB2B2] to-[#088395] text-white font-semibold shadow-md hover:shadow-lg hover:-translate-y-0.5 transition">
                    Verify
                </button>

                <div class="text-center text-sm text-gray-500 mt-6">
                    <a href="@Url.Action("Login", "Home")" class="text-[#088395] hover:underline">Back to login</a>
                </div>
            </form>
        }
    </div>
</div>
