@{
    var totalOrgs = (int)(ViewData["TotalOrganizations"] ?? 0);
    var totalUsers = (int)(ViewData["TotalUsers"] ?? 0);
    var totalSources = (int)(ViewData["TotalSources"] ?? 0);
    var totalSubmissions = (int)(ViewData["TotalSubmissions"] ?? 0);
    var totalAuditLogs = (int)(ViewData["TotalAuditLogs"] ?? 0);
    var totalWarehouseRows = (int)(ViewData["TotalWarehouseRows"] ?? 0);
    var totalStagingRows = (int)(ViewData["TotalStagingRows"] ?? 0);
    var validRows = (int)(ViewData["ValidRows"] ?? 0);
    var errorRows = (int)(ViewData["ErrorRows"] ?? 0);
    var dataQuality = (double)(ViewData["DataQuality"] ?? 0.0);
    var totalRevenue = (decimal)(ViewData["TotalRevenue"] ?? 0m);
    var thisMonthRevenue = (decimal)(ViewData["ThisMonthRevenue"] ?? 0m);

    var planDistribution = ViewData["PlanDistribution"] as dynamic;
    var orgActivity = ViewData["OrgActivity"] as dynamic;
    var submissionStatus = ViewData["SubmissionStatus"] as dynamic;
    var monthlySubmissions = ViewData["MonthlySubmissions"] as dynamic;
    var userGrowth = ViewData["UserGrowth"] as dynamic;
    var actionBreakdown = ViewData["ActionBreakdown"] as dynamic;
    var failedByOrg = ViewData["FailedByOrg"] as dynamic;
}

<div class="py-6 min-h-full">

    <!-- Page Header -->
    <div class="mb-8">
        <h2 class="text-xl font-bold" style="color: #09637E;">Platform Reports</h2>
        <p class="text-sm text-gray-500 mt-1">System-wide analytics across all organizations, users, and data pipelines.</p>
    </div>

    <!-- Platform KPI Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-4 mb-8">
        <div class="rounded-2xl p-5 text-white" style="background: linear-gradient(135deg, #088395, #7AB2B2);">
            <p class="text-2xl font-bold">@totalOrgs</p>
            <p class="text-xs mt-1" style="color: rgba(255,255,255,0.8);">Organizations</p>
        </div>
        <div class="rounded-2xl p-5 text-white" style="background: linear-gradient(135deg, #09637E, #088395);">
            <p class="text-2xl font-bold">@totalUsers</p>
            <p class="text-xs mt-1" style="color: rgba(255,255,255,0.8);">Total Users</p>
        </div>
        <div class="rounded-2xl p-5 text-white" style="background: linear-gradient(135deg, #7AB2B2, #088395);">
            <p class="text-2xl font-bold">@totalSources</p>
            <p class="text-xs mt-1" style="color: rgba(255,255,255,0.8);">Data Sources</p>
        </div>
        <div class="rounded-2xl p-5 text-white" style="background: linear-gradient(135deg, #088395, #09637E);">
            <p class="text-2xl font-bold">@totalSubmissions</p>
            <p class="text-xs mt-1" style="color: rgba(255,255,255,0.8);">Submissions</p>
        </div>
        <div class="rounded-2xl p-5 text-white" style="background: linear-gradient(135deg, #09637E, #7AB2B2);">
            <p class="text-2xl font-bold">@(totalWarehouseRows.ToString("N0"))</p>
            <p class="text-xs mt-1" style="color: rgba(255,255,255,0.8);">Warehouse Rows</p>
        </div>
        <div class="rounded-2xl p-5 text-white" style="background: linear-gradient(135deg, #7AB2B2, #09637E);">
            <p class="text-2xl font-bold">@(totalAuditLogs.ToString("N0"))</p>
            <p class="text-xs mt-1" style="color: rgba(255,255,255,0.8);">Audit Entries</p>
        </div>
    </div>

    <!-- Row: Revenue + Plan Distribution + Data Quality -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">

        <!-- Revenue Summary -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <div class="flex items-center gap-3 mb-5">
                <div class="w-9 h-9 rounded-full flex items-center justify-center" style="background: #EBF4F6; color: #088395;">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-base font-bold" style="color: #09637E;">Revenue</h3>
                    <p class="text-xs text-gray-400">Platform income summary</p>
                </div>
            </div>
            <div class="space-y-4">
                <div class="border rounded-xl p-4" style="border-color: #EBF4F6;">
                    <p class="text-xs text-gray-400">Total Revenue</p>
                    <p class="text-xl font-bold" style="color: #09637E;">₱@totalRevenue.ToString("N2")</p>
                </div>
                <div class="border rounded-xl p-4" style="border-color: #EBF4F6;">
                    <p class="text-xs text-gray-400">This Month</p>
                    <p class="text-xl font-bold" style="color: #088395;">₱@thisMonthRevenue.ToString("N2")</p>
                </div>
            </div>
        </div>

        <!-- Subscription Plan Distribution -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <div class="flex items-center gap-3 mb-5">
                <div class="w-9 h-9 rounded-full flex items-center justify-center" style="background: #EBF4F6; color: #09637E;">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-base font-bold" style="color: #09637E;">Plan Distribution</h3>
                    <p class="text-xs text-gray-400">Organizations by subscription tier</p>
                </div>
            </div>
            @if (planDistribution != null && ((IEnumerable<dynamic>)planDistribution!).Any())
            {
                <div class="space-y-3">
                    @foreach (var p in (IEnumerable<dynamic>)planDistribution!)
                    {
                        var planColor = (string)p.Plan == "Premium" ? "background: #09637E;" :
                                        (string)p.Plan == "Basic" ? "background: #088395;" : "background: #7AB2B2;";
                        var pct = totalOrgs > 0 ? Math.Round((double)(int)p.Count * 100.0 / totalOrgs, 0) : 0;
                        <div>
                            <div class="flex justify-between text-sm mb-1">
                                <span class="text-gray-700 font-medium">@p.Plan</span>
                                <span class="text-gray-800 font-bold">@p.Count <span class="text-gray-400 font-normal text-xs">(@(pct)%)</span></span>
                            </div>
                            <div class="w-full rounded-full h-2" style="background: #EBF4F6;">
                                <div class="h-2 rounded-full" style="@planColor width: @(pct)%;"></div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-sm text-gray-400 text-center py-6">No organizations yet.</p>
            }
        </div>

        <!-- Data Quality -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <div class="flex items-center gap-3 mb-5">
                <div class="w-9 h-9 rounded-full flex items-center justify-center" style="background: #EBF4F6; color: #088395;">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-base font-bold" style="color: #09637E;">Data Quality</h3>
                    <p class="text-xs text-gray-400">Platform-wide validation metrics</p>
                </div>
            </div>
            <div class="text-center mb-4">
                <p class="text-3xl font-bold" style="color: #088395;">@dataQuality%</p>
                <p class="text-xs text-gray-400 mt-1">Overall Quality Score</p>
            </div>
            <div class="space-y-3">
                <div>
                    <div class="flex justify-between text-xs mb-1">
                        <span class="text-gray-500">Valid Rows</span>
                        <span class="font-semibold text-green-600">@(validRows.ToString("N0"))</span>
                    </div>
                    <div class="w-full rounded-full h-1.5" style="background: #EBF4F6;">
                        <div class="bg-green-500 h-1.5 rounded-full" style="width: @(totalStagingRows > 0 ? validRows * 100 / totalStagingRows : 0)%;"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between text-xs mb-1">
                        <span class="text-gray-500">Error Rows</span>
                        <span class="font-semibold text-red-500">@(errorRows.ToString("N0"))</span>
                    </div>
                    <div class="w-full rounded-full h-1.5" style="background: #EBF4F6;">
                        <div class="bg-red-500 h-1.5 rounded-full" style="width: @(totalStagingRows > 0 ? errorRows * 100 / totalStagingRows : 0)%;"></div>
                    </div>
                </div>
                <p class="text-xs text-gray-400 text-center mt-2">@(totalStagingRows.ToString("N0")) total staging rows</p>
            </div>
        </div>
    </div>

    <!-- Submission Status Platform-wide -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 mb-8">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background: #EBF4F6; color: #09637E;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">Submission Status (Platform-wide)</h3>
                <p class="text-xs text-gray-400">Breakdown of all data submissions across every organization</p>
            </div>
        </div>
        @if (submissionStatus != null && ((IEnumerable<dynamic>)submissionStatus!).Any())
        {
            <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
                @foreach (var item in (IEnumerable<dynamic>)submissionStatus!)
                {
                    var color = (string)item.Status switch {
                        "Integrated" => "border-green-400 bg-green-50 text-green-700",
                        "Submitted" => "border-amber-400 bg-amber-50 text-amber-700",
                        "Failed" => "border-red-400 bg-red-50 text-red-700",
                        "Verified" => "border-blue-400 bg-blue-50 text-blue-700",
                        _ => "border-gray-300 bg-gray-50 text-gray-700"
                    };
                    <div class="border-2 rounded-xl p-5 @color">
                        <p class="text-2xl font-bold">@item.Count</p>
                        <p class="text-sm font-semibold mt-1">@item.Status</p>
                        <p class="text-xs opacity-70 mt-1">@(((int)item.Rows).ToString("N0")) total rows</p>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-sm text-gray-400 text-center py-6">No submission data available.</p>
        }
    </div>

    <!-- Row: Organization Activity + Failed by Org -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">

        <!-- Organization Activity Ranking -->
        <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background: #EBF4F6; color: #088395;">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold" style="color: #09637E;">Organization Activity</h3>
                    <p class="text-xs text-gray-400">Ranked by submission volume across all organizations</p>
                </div>
            </div>
            @if (orgActivity != null && ((IEnumerable<dynamic>)orgActivity!).Any())
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr style="border-bottom: 2px solid #EBF4F6;">
                                <th class="text-left py-3 px-3 font-semibold text-xs" style="color: #088395;">#</th>
                                <th class="text-left py-3 px-3 font-semibold text-xs" style="color: #088395;">Organization</th>
                                <th class="text-center py-3 px-3 font-semibold text-xs" style="color: #088395;">Plan</th>
                                <th class="text-center py-3 px-3 font-semibold text-xs" style="color: #088395;">Users</th>
                                <th class="text-center py-3 px-3 font-semibold text-xs" style="color: #088395;">Sources</th>
                                <th class="text-center py-3 px-3 font-semibold text-xs" style="color: #088395;">Submissions</th>
                                <th class="text-center py-3 px-3 font-semibold text-xs" style="color: #088395;">Warehouse Rows</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var rank = 1; }
                            @foreach (var o in (IEnumerable<dynamic>)orgActivity!)
                            {
                                var planBadge = (string)o.SubscriptionPlan == "Premium" ? "text-purple-700 bg-purple-50" :
                                                (string)o.SubscriptionPlan == "Basic" ? "text-blue-700 bg-blue-50" : "text-gray-600 bg-gray-100";
                                <tr class="border-b border-gray-100 hover:bg-gray-50">
                                    <td class="py-3 px-3 font-bold text-gray-400">@rank</td>
                                    <td class="py-3 px-3 font-semibold text-gray-800">@o.OrganizationName</td>
                                    <td class="py-3 px-3 text-center"><span class="text-xs font-medium px-2 py-0.5 rounded-full @planBadge">@o.SubscriptionPlan</span></td>
                                    <td class="py-3 px-3 text-center text-gray-600">@o.UserCount</td>
                                    <td class="py-3 px-3 text-center text-gray-600">@o.SourceCount</td>
                                    <td class="py-3 px-3 text-center font-semibold" style="color: #09637E;">@o.SubmissionCount</td>
                                    <td class="py-3 px-3 text-center text-gray-600">@(((int)o.WarehouseRows).ToString("N0"))</td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-sm text-gray-400 text-center py-6">No organizations yet.</p>
            }
        </div>

        <!-- Failed Submissions by Org -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-full flex items-center justify-center bg-red-50 text-red-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-red-700">Failed Submissions</h3>
                    <p class="text-xs text-gray-400">Top organizations with failures</p>
                </div>
            </div>
            @if (failedByOrg != null && ((IEnumerable<dynamic>)failedByOrg!).Any())
            {
                <div class="space-y-3">
                    @foreach (var f in (IEnumerable<dynamic>)failedByOrg!)
                    {
                        <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
                            <span class="text-sm text-gray-700 font-medium">@f.OrgName</span>
                            <span class="text-sm font-bold text-red-600">@f.Count</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-6">
                    <span class="text-green-500 text-2xl">&#10003;</span>
                    <p class="text-sm text-gray-400 mt-2">No failed submissions across the platform.</p>
                </div>
            }
        </div>
    </div>

    <!-- Row: Monthly Submissions + User Growth -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">

        <!-- Monthly Submission Trend -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background: #EBF4F6; color: #088395;">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold" style="color: #09637E;">Monthly Submissions</h3>
                    <p class="text-xs text-gray-400">Platform-wide trend (last 12 months)</p>
                </div>
            </div>
            @if (monthlySubmissions != null && ((IEnumerable<dynamic>)monthlySubmissions!).Any())
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr style="border-bottom: 2px solid #EBF4F6;">
                                <th class="text-left py-2 px-3 font-semibold text-xs" style="color: #088395;">Month</th>
                                <th class="text-center py-2 px-3 font-semibold text-xs" style="color: #088395;">Submissions</th>
                                <th class="text-center py-2 px-3 font-semibold text-xs" style="color: #088395;">Rows</th>
                                <th class="text-left py-2 px-3 font-semibold text-xs" style="color: #088395;">Volume</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int maxSubRows = 1;
                                foreach (var m in (IEnumerable<dynamic>)monthlySubmissions!) { if ((int)m.Rows > maxSubRows) maxSubRows = (int)m.Rows; }
                            }
                            @foreach (var m in (IEnumerable<dynamic>)monthlySubmissions!)
                            {
                                var monthName = new DateTime((int)m.Year, (int)m.Month, 1).ToString("MMM yyyy");
                                var pct = maxSubRows > 0 ? (int)m.Rows * 100 / maxSubRows : 0;
                                <tr class="border-b border-gray-100 hover:bg-gray-50">
                                    <td class="py-2 px-3 font-semibold text-gray-800 text-xs">@monthName</td>
                                    <td class="py-2 px-3 text-center text-gray-600">@m.Count</td>
                                    <td class="py-2 px-3 text-center text-gray-600">@(((int)m.Rows).ToString("N0"))</td>
                                    <td class="py-2 px-3 w-1/3">
                                        <div class="w-full rounded-full h-2" style="background: #EBF4F6;">
                                            <div class="h-2 rounded-full" style="background: #088395; width: @(pct)%;"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-sm text-gray-400 text-center py-6">No submission history yet.</p>
            }
        </div>

        <!-- User Growth -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background: #EBF4F6; color: #09637E;">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold" style="color: #09637E;">User Growth</h3>
                    <p class="text-xs text-gray-400">New registrations per month (last 12 months)</p>
                </div>
            </div>
            @if (userGrowth != null && ((IEnumerable<dynamic>)userGrowth!).Any())
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr style="border-bottom: 2px solid #EBF4F6;">
                                <th class="text-left py-2 px-3 font-semibold text-xs" style="color: #088395;">Month</th>
                                <th class="text-center py-2 px-3 font-semibold text-xs" style="color: #088395;">New Users</th>
                                <th class="text-left py-2 px-3 font-semibold text-xs" style="color: #088395;">Growth</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int maxUserCount = 1;
                                foreach (var u in (IEnumerable<dynamic>)userGrowth!) { if ((int)u.Count > maxUserCount) maxUserCount = (int)u.Count; }
                            }
                            @foreach (var u in (IEnumerable<dynamic>)userGrowth!)
                            {
                                var monthName = new DateTime((int)u.Year, (int)u.Month, 1).ToString("MMM yyyy");
                                var pct = maxUserCount > 0 ? (int)u.Count * 100 / maxUserCount : 0;
                                <tr class="border-b border-gray-100 hover:bg-gray-50">
                                    <td class="py-2 px-3 font-semibold text-gray-800 text-xs">@monthName</td>
                                    <td class="py-2 px-3 text-center font-bold" style="color: #09637E;">@u.Count</td>
                                    <td class="py-2 px-3 w-1/2">
                                        <div class="w-full rounded-full h-2" style="background: #EBF4F6;">
                                            <div class="h-2 rounded-full" style="background: #09637E; width: @(pct)%;"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-sm text-gray-400 text-center py-6">No user registrations yet.</p>
            }
        </div>
    </div>

    <!-- Audit Action Breakdown -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background: #EBF4F6; color: #088395;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">Audit Actions</h3>
                <p class="text-xs text-gray-400">Total actions logged across the entire platform</p>
            </div>
        </div>
        @if (actionBreakdown != null && ((IEnumerable<dynamic>)actionBreakdown!).Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                @{
                    var topActionCount = 1;
                    var firstAction = ((IEnumerable<dynamic>)actionBreakdown!).FirstOrDefault();
                    if (firstAction != null) topActionCount = (int)firstAction.Count > 0 ? (int)firstAction.Count : 1;
                }
                @foreach (var ab in (IEnumerable<dynamic>)actionBreakdown!)
                {
                    var barPct = Math.Round((double)(int)ab.Count * 100.0 / topActionCount, 0);
                    <div class="border rounded-xl p-4" style="border-color: #EBF4F6;">
                        <div class="flex justify-between text-sm mb-2">
                            <span class="text-gray-700 font-medium">@ab.Action</span>
                            <span class="text-gray-800 font-bold">@ab.Count</span>
                        </div>
                        <div class="w-full rounded-full h-1.5" style="background: #EBF4F6;">
                            <div class="h-1.5 rounded-full" style="background: #088395; width: @(barPct)%;"></div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-sm text-gray-400 text-center py-6">No audit logs recorded yet.</p>
        }
    </div>
</div>
