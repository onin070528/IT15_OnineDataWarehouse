@using it15_webproject_mvc.Models
@{
    var allPayments = ViewData["AllPayments"] as List<Payment> ?? new List<Payment>();
    var totalRevenue = (decimal)(ViewData["TotalRevenue"] ?? 0m);
    var totalPaidCount = (int)(ViewData["TotalPaidCount"] ?? 0);
    var pendingPayments = (int)(ViewData["PendingPayments"] ?? 0);
    var totalTransactions = (int)(ViewData["TotalTransactions"] ?? 0);
    var thisMonthRevenue = (decimal)(ViewData["ThisMonthRevenue"] ?? 0m);
    var thisMonthCount = (int)(ViewData["ThisMonthCount"] ?? 0);
    var monthlyIncome = ViewData["MonthlyIncome"] as IEnumerable<dynamic>;
    var revenueByPlan = ViewData["RevenueByPlan"] as IEnumerable<dynamic>;
    var revenueByOrg = ViewData["RevenueByOrg"] as IEnumerable<dynamic>;
}

<div class="py-6 min-h-full">

    <!-- Revenue KPI Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
        <div class="rounded-2xl p-6 text-white" style="background: linear-gradient(135deg, #088395, #09637E);">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-3xl font-bold">₱@totalRevenue.ToString("N2")</p>
                    <p class="text-sm mt-1" style="color: rgba(255,255,255,0.8);">Total Revenue</p>
                </div>
                <svg class="w-8 h-8" style="color: rgba(255,255,255,0.4);" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <p class="text-xs mt-2" style="color: rgba(255,255,255,0.65);">From @totalPaidCount paid subscription(s)</p>
        </div>
        <div class="rounded-2xl p-6 text-white" style="background: linear-gradient(135deg, #09637E, #088395);">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-3xl font-bold">₱@thisMonthRevenue.ToString("N2")</p>
                    <p class="text-sm mt-1" style="color: rgba(255,255,255,0.8);">This Month</p>
                </div>
                <svg class="w-8 h-8" style="color: rgba(255,255,255,0.4);" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
            </div>
            <p class="text-xs mt-2" style="color: rgba(255,255,255,0.65);">@thisMonthCount payment(s) this month</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <p class="text-2xl font-bold" style="color: #088395;">@totalPaidCount</p>
            <p class="text-xs text-gray-400 mt-1">Paid Subscriptions</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <p class="text-2xl font-bold text-yellow-600">@pendingPayments</p>
            <p class="text-xs text-gray-400 mt-1">Pending Payments</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">

        <!-- Revenue by Plan -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background: #EBF4F6; color: #088395;">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold" style="color: #09637E;">Revenue by Plan</h3>
                    <p class="text-xs text-gray-400">Income breakdown by subscription tier</p>
                </div>
            </div>
            @if (revenueByPlan != null && revenueByPlan.Any())
            {
                var topPlanRevenue = revenueByPlan.Max(r => (decimal)r.Total);
                topPlanRevenue = topPlanRevenue > 0 ? topPlanRevenue : 1;
                <div class="space-y-5">
                    @foreach (var rp in revenueByPlan)
                    {
                        var barPct = Math.Round((double)(decimal)rp.Total * 100.0 / (double)topPlanRevenue, 0);
                        var planColor = ((string)rp.Plan).Contains("Premium") ? "background: linear-gradient(135deg, #088395, #09637E);" : "background: #7AB2B2;";
                        <div>
                            <div class="flex justify-between text-sm mb-1">
                                <span class="text-gray-700 font-semibold">@rp.Plan</span>
                                <span class="font-bold" style="color: #09637E;">₱@(((decimal)rp.Total).ToString("N2")) <span class="text-xs text-gray-400 font-normal">(@rp.Count payments)</span></span>
                            </div>
                            <div class="w-full rounded-full h-3" style="background: #EBF4F6;">
                                <div class="h-3 rounded-full" style="@planColor width: @(barPct)%;"></div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-sm text-gray-400 text-center py-6">No revenue data yet.</p>
            }
        </div>

        <!-- Revenue by Organization -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background: #EBF4F6; color: #09637E;">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold" style="color: #09637E;">Revenue by Organization</h3>
                    <p class="text-xs text-gray-400">Top paying organizations</p>
                </div>
            </div>
            @if (revenueByOrg != null && revenueByOrg.Any())
            {
                var topOrgRevenue = revenueByOrg.Max(r => (decimal)r.Total);
                topOrgRevenue = topOrgRevenue > 0 ? topOrgRevenue : 1;
                <div class="space-y-4">
                    @foreach (var ro in revenueByOrg)
                    {
                        var barPct = Math.Round((double)(decimal)ro.Total * 100.0 / (double)topOrgRevenue, 0);
                        <div>
                            <div class="flex justify-between text-sm mb-1">
                                <span class="text-gray-700 font-medium">@ro.OrgName</span>
                                <span class="font-bold" style="color: #09637E;">₱@(((decimal)ro.Total).ToString("N2"))</span>
                            </div>
                            <div class="w-full rounded-full h-2.5" style="background: #EBF4F6;">
                                <div class="h-2.5 rounded-full" style="background: #088395; width: @(barPct)%;"></div>
                            </div>
                            <p class="text-xs text-gray-400 mt-0.5">@ro.Count payment(s)</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-sm text-gray-400 text-center py-6">No revenue data yet.</p>
            }
        </div>
    </div>

    <!-- Monthly Income History -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 mb-8">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background: #EBF4F6; color: #088395;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">Monthly Income</h3>
                <p class="text-xs text-gray-400">Revenue collected per month</p>
            </div>
        </div>
        @if (monthlyIncome != null && monthlyIncome.Any())
        {
            var topMonthly = monthlyIncome.Max(m => (decimal)m.Total);
            topMonthly = topMonthly > 0 ? topMonthly : 1;
            <div class="space-y-4">
                @foreach (var mi in monthlyIncome)
                {
                    var monthName = new DateTime((int)mi.Year, (int)mi.Month, 1).ToString("MMM yyyy");
                    var barPct = Math.Round((double)(decimal)mi.Total * 100.0 / (double)topMonthly, 0);
                    <div class="flex items-center gap-4">
                        <span class="w-24 text-sm text-gray-600 font-medium flex-shrink-0">@monthName</span>
                        <div class="flex-1">
                            <div class="w-full rounded-full h-4" style="background: #EBF4F6;">
                                <div class="h-4 rounded-full flex items-center px-2" style="background: linear-gradient(135deg, #088395, #7AB2B2); width: @(barPct)%; min-width: 60px;">
                                    <span class="text-[10px] font-bold text-white whitespace-nowrap">₱@(((decimal)mi.Total).ToString("N0"))</span>
                                </div>
                            </div>
                        </div>
                        <span class="text-xs text-gray-400 flex-shrink-0 w-20 text-right">@mi.Count payment(s)</span>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-sm text-gray-400 text-center py-6">No monthly income data yet.</p>
        }
    </div>

    <!-- All Payment Transactions -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background: #EBF4F6; color: #088395;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">All Payment Transactions</h3>
                <p class="text-xs text-gray-400">@totalTransactions total transaction(s) across the platform</p>
            </div>
        </div>
        @if (allPayments.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr style="border-bottom: 2px solid #EBF4F6;">
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">ID</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Subscriber</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Organization</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Plan</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Amount</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Created</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Paid At</th>
                            <th class="text-center py-3 px-4 font-semibold" style="color: #088395;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in allPayments)
                        {
                            var statusBg = p.Status == "Paid" ? "text-green-600 bg-green-50" :
                                           p.Status == "Pending" ? "text-yellow-600 bg-yellow-50" : "text-red-600 bg-red-50";
                            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                                <td class="py-3 px-4 font-mono text-xs text-gray-500">#@p.PaymentID</td>
                                <td class="py-3 px-4">
                                    <div>
                                        <p class="font-semibold text-gray-800">@(p.User?.Full_name ?? "Unknown")</p>
                                        <p class="text-xs text-gray-400">@(p.User?.Email ?? "—")</p>
                                    </div>
                                </td>
                                <td class="py-3 px-4 text-gray-600">@(p.Organization?.OrganizationName ?? "—")</td>
                                <td class="py-3 px-4">
                                    <span class="text-xs font-semibold px-2 py-0.5 rounded-full" style="background: #EBF4F6; color: #09637E;">@p.PlanName</span>
                                </td>
                                <td class="py-3 px-4 font-bold" style="color: #09637E;">₱@p.Amount.ToString("N2")</td>
                                <td class="py-3 px-4 text-gray-500 text-xs">@p.Created_at.ToString("MMM dd, yyyy hh:mm tt")</td>
                                <td class="py-3 px-4 text-gray-500 text-xs">@(p.Paid_at?.ToString("MMM dd, yyyy hh:mm tt") ?? "—")</td>
                                <td class="py-3 px-4 text-center">
                                    <span class="text-xs font-medium px-2.5 py-1 rounded-full @statusBg">@p.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-12 text-gray-400">
                <svg class="w-12 h-12 mx-auto mb-4" style="color: #7AB2B2;" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-sm font-medium">No payment transactions yet</p>
                <p class="text-xs mt-1">Income data will appear here when organizations subscribe to paid plans</p>
            </div>
        }
    </div>
</div>
