@using System.Security.Claims
@{
    var orgName = ViewData["OrganizationName"] as string ?? "My Company";
    ViewData["Title"] = orgName + " - Data Warehouse";
    var section = (ViewData["Section"] as string ?? "dashboard").ToLower();
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "SuperAdmin";
}

<style>
    :root {
        --sa-lightest: #EBF4F6;
        --sa-light: #7AB2B2;
        --sa-primary: #088395;
        --sa-dark: #09637E;
    }
    .sa-nav { background: linear-gradient(135deg, var(--sa-dark), var(--sa-primary)); }
    .sa-nav-link { color: rgba(255,255,255,0.75); transition: all 0.2s; }
    .sa-nav-link:hover { color: #fff; background: rgba(255,255,255,0.1); }
    .sa-nav-link.active { color: #fff; background: rgba(255,255,255,0.18); box-shadow: inset 0 -3px 0 var(--sa-lightest); }
    .sa-body { background: var(--sa-lightest); }
    .sa-avatar { background: var(--sa-light); color: #fff; }
    .sa-logout { background: rgba(255,255,255,0.12); color: #fff; }
    .sa-logout:hover { background: rgba(255,255,255,0.25); }
    .sa-mobile-toggle { display: none; }
    @@media (max-width: 768px) {
        .sa-mobile-toggle { display: flex; }
        .sa-nav-links { display: none; }
        .sa-nav-links.open { display: flex; flex-direction: column; position: absolute; top: 100%; left: 0; right: 0; background: var(--sa-dark); padding: 0.5rem 1rem 1rem; z-index: 50; }
    }
</style>

<div class="min-h-screen sa-body">

    <!-- TOP NAVBAR -->
    <nav class="sa-nav sticky top-0 z-50 shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16 relative">
                <!-- Brand -->
                <a href="@Url.Action("Supernav", "SuperAdmin", new { section = "dashboard" })" class="flex items-center gap-2 no-underline flex-shrink-0">
                    <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--sa-lightest);">
                        <svg class="w-5 h-5" style="color: var(--sa-dark);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                        </svg>
                    </div>
                    <span class="text-white font-bold text-lg hidden sm:inline">@orgName</span>
                </a>

                <!-- Mobile menu toggle -->
                <button onclick="document.getElementById('sa-nav-links').classList.toggle('open')"
                        class="sa-mobile-toggle items-center justify-center w-10 h-10 rounded-lg text-white hover:bg-white/10">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                </button>

                <!-- Nav Links -->
                <div id="sa-nav-links" class="sa-nav-links flex items-center gap-1">
                    <a href="@Url.Action("Supernav", "SuperAdmin", new { section = "dashboard" })"
                       class="sa-nav-link @(section == "dashboard" ? "active" : "") flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium no-underline">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                        </svg>
                        Dashboard
                    </a>
                    <a href="@Url.Action("Supernav", "SuperAdmin", new { section = "reports" })"
                       class="sa-nav-link @(section == "reports" ? "active" : "") flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium no-underline">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        Reports
                    </a>
                    <a href="@Url.Action("Supernav", "SuperAdmin", new { section = "subscriptions" })"
                       class="sa-nav-link @(section == "subscriptions" ? "active" : "") flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium no-underline">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                        </svg>
                        Subscriptions
                    </a>
                    <a href="@Url.Action("Supernav", "SuperAdmin", new { section = "sales" })"
                       class="sa-nav-link @(section == "sales" ? "active" : "") flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium no-underline">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Sales & Income
                    </a>
                    <a href="@Url.Action("Supernav", "SuperAdmin", new { section = "users" })"
                       class="sa-nav-link @(section == "users" ? "active" : "") flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium no-underline">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        Users
                    </a>
                </div>

                <!-- Right: User + Logout -->
                <div class="flex items-center gap-3">
                    <partial name="_NotificationBell" />
                    <div class="hidden sm:flex items-center gap-2">
                        <span class="sa-avatar inline-flex items-center justify-center w-8 h-8 rounded-full text-xs font-bold">
                            @(User.Identity?.Name?.Substring(0, Math.Min(2, User.Identity?.Name?.Length ?? 0)).ToUpper() ?? "SA")
                        </span>
                        <div class="hidden md:block">
                            <p class="text-white text-sm font-semibold leading-tight">@User.Identity?.Name</p>
                            <p class="text-white/60 text-xs leading-tight">@userRole</p>
                        </div>
                    </div>
                    <a href="/auth/logout"
                       class="sa-logout flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium no-underline transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                        </svg>
                        Logout
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Page Header -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-2">
        <h1 class="text-2xl font-bold" style="color: var(--sa-dark);">
            @(section switch
            {
                "reports" => "Reports & Analytics",
                "subscriptions" => "Subscriptions",
                "sales" => "Sales & Income",
                "users" => "User Management",
                _ => "Dashboard"
            })
        </h1>
    </div>

    <!-- Page Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-10">
        @if (section == "reports")
        {
            <partial name="SuperReports" />
        }
        else if (section == "subscriptions")
        {
            <partial name="SuperSubs" />
        }
        else if (section == "sales")
        {
            <partial name="SuperSales" />
        }
        else if (section == "users")
        {
            <partial name="SuperUsers" />
        }
        else
        {
            <partial name="SuperDashboard" />
        }
    </main>
</div>

