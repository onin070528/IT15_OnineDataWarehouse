@{
    ViewData["Title"] = "Reset Password";
    var token = (ViewData["Token"] as string) ?? string.Empty;
    var e = Context.Request.Query["error"].ToString();
}

<div class="min-h-screen flex items-center justify-center bg-white p-8">
    <div class="w-full max-w-md">
        <div class="mb-8 text-center">
            <h2 class="text-2xl font-bold text-gray-900">Reset Password</h2>
            <p class="text-sm text-gray-500 mt-2">Set your new password.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(e))
        {
            <div class="flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 shadow-sm">
                <span class="text-lg">&#9888;</span>
                <div>@e</div>
            </div>
        }

        @if (string.IsNullOrWhiteSpace(token))
        {
            <div class="bg-amber-50 border border-amber-200 text-amber-700 px-4 py-3 rounded-lg mb-6">
                Invalid reset link. Please request a new one.
            </div>
            <div class="text-center">
                <a href="@Url.Action("ForgotPassword", "Home")" class="text-[#088395] hover:underline">Go to forgot password</a>
            </div>
        }
        else
        {
            <form method="post" action="/auth/reset-password" class="space-y-6">
                @Html.AntiForgeryToken()
                <input type="hidden" name="token" value="@token" />

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">New Password</label>
                    <input id="newPassword"
                           name="password"
                           type="password"
                           class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-4 focus:ring-[#088395]/20 focus:border-[#088395] transition"
                           placeholder="••••••••"
                           required />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Confirm New Password</label>
                    <input id="confirmPassword"
                           name="confirmPassword"
                           type="password"
                           class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-4 focus:ring-[#088395]/20 focus:border-[#088395] transition"
                           placeholder="••••••••"
                           required />
                    <p class="text-xs text-gray-500 mt-2">Must be at least 12 characters, include at least one special character, and avoid your username or common passwords.</p>
                </div>

                <button type="submit"
                        class="w-full py-3 rounded-lg bg-gradient-to-r from-[#7AB2B2] to-[#088395] text-white font-semibold shadow-md hover:shadow-lg hover:-translate-y-0.5 transition">
                    Reset Password
                </button>

                <div class="text-center text-sm text-gray-500 mt-6">
                    <a href="@Url.Action("Login", "Home")" class="text-[#088395] hover:underline">Back to login</a>
                </div>
            </form>
        }
    </div>
</div>

<script>
    function togglePassword(id) {
        const input = document.getElementById(id);
        if (!input) {
            return;
        }
        input.type = input.type === "password" ? "text" : "password";
    }
</script>
