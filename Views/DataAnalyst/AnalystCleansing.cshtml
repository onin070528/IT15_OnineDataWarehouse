@{
    var totalRows = (int)(ViewData["TotalRows"] ?? 0);
    var validRows = (int)(ViewData["ValidRows"] ?? 0);
    var errorRows = (int)(ViewData["ErrorRows"] ?? 0);
    var warningRows = (int)(ViewData["WarningRows"] ?? 0);
    var pendingRows = (int)(ViewData["PendingRows"] ?? 0);
    var successRate = (double)(ViewData["SuccessRate"] ?? 0.0);
    var allBatches = ViewData["AllBatches"] as IEnumerable<dynamic>;
    var qualityBySource = ViewData["QualityBySource"] as dynamic;
    var commonIssues = ViewData["CommonIssues"] as dynamic;
}

<div class="p-8 min-h-full" style="background-color: #EBF4F6;">

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-5 mb-8">
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <p class="text-2xl font-bold" style="color: #09637E;">@totalRows.ToString("N0")</p>
            <p class="text-xs text-gray-400 mt-1">Total Rows</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <p class="text-2xl font-bold text-green-600">@validRows.ToString("N0")</p>
            <p class="text-xs text-gray-400 mt-1">Valid</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <p class="text-2xl font-bold text-yellow-600">@warningRows.ToString("N0")</p>
            <p class="text-xs text-gray-400 mt-1">Warnings</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <p class="text-2xl font-bold text-red-500">@errorRows.ToString("N0")</p>
            <p class="text-xs text-gray-400 mt-1">Errors</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <p class="text-2xl font-bold" style="color: #088395;">@successRate%</p>
            <p class="text-xs text-gray-400 mt-1">Success Rate</p>
        </div>
    </div>

    <!-- Quality Bar -->
    @if (totalRows > 0)
    {
        <div class="bg-white rounded-2xl shadow-sm p-6 mb-8" style="border: 1px solid #7AB2B2;">
            <h4 class="text-sm font-bold text-gray-900 mb-3">Overall Data Quality</h4>
            <div class="flex w-full rounded-full h-4 overflow-hidden bg-gray-100">
                @if (validRows > 0)
                {
                    <div class="bg-green-500 h-4" style="width: @(Math.Round(validRows * 100.0 / totalRows, 1))%;" title="Valid: @validRows"></div>
                }
                @if (warningRows > 0)
                {
                    <div class="bg-yellow-400 h-4" style="width: @(Math.Round(warningRows * 100.0 / totalRows, 1))%;" title="Warnings: @warningRows"></div>
                }
                @if (errorRows > 0)
                {
                    <div class="bg-red-500 h-4" style="width: @(Math.Round(errorRows * 100.0 / totalRows, 1))%;" title="Errors: @errorRows"></div>
                }
                @if (pendingRows > 0)
                {
                    <div class="bg-gray-300 h-4" style="width: @(Math.Round(pendingRows * 100.0 / totalRows, 1))%;" title="Pending: @pendingRows"></div>
                }
            </div>
            <div class="flex items-center gap-6 mt-3 text-xs text-gray-500">
                <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-green-500"></span> Valid (@validRows)</span>
                <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-yellow-400"></span> Warning (@warningRows)</span>
                <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-500"></span> Error (@errorRows)</span>
                <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-gray-300"></span> Pending (@pendingRows)</span>
            </div>
        </div>
    }

    <!-- Quality per Source + Common Issues side by side -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">

        <!-- Quality per Source -->
        @if (qualityBySource != null && ((System.Collections.ICollection)qualityBySource!).Count > 0)
        {
            <div class="bg-white rounded-2xl shadow-sm p-8" style="border: 1px solid #7AB2B2;">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold" style="color: #09637E;">Quality by Source</h3>
                        <p class="text-xs text-gray-400">Validation breakdown per data source</p>
                    </div>
                </div>
                <div class="space-y-4">
                    @foreach (var src in (IEnumerable<dynamic>)qualityBySource!)
                    {
                        var srcTotal = (int)src.TotalRows;
                        var srcValid = (int)src.ValidRows;
                        var srcRate = srcTotal > 0 ? Math.Round(srcValid * 100.0 / srcTotal, 1) : 0;
                        <div class="rounded-xl p-4" style="border: 1px solid #EBF4F6;">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-sm font-semibold text-gray-800">@src.SourceName</span>
                                <span class="text-xs font-bold" style="color: @(srcRate >= 80 ? "#16a34a" : srcRate >= 50 ? "#ca8a04" : "#dc2626");">@srcRate%</span>
                            </div>
                            <div class="flex w-full rounded-full h-2 overflow-hidden bg-gray-100">
                                @if (srcValid > 0)
                                {
                                    <div class="bg-green-500 h-2" style="width: @(srcTotal > 0 ? Math.Round(srcValid * 100.0 / srcTotal, 1) : 0)%;"></div>
                                }
                                @if ((int)src.WarningRows > 0)
                                {
                                    <div class="bg-yellow-400 h-2" style="width: @(srcTotal > 0 ? Math.Round((int)src.WarningRows * 100.0 / srcTotal, 1) : 0)%;"></div>
                                }
                                @if ((int)src.ErrorRows > 0)
                                {
                                    <div class="bg-red-500 h-2" style="width: @(srcTotal > 0 ? Math.Round((int)src.ErrorRows * 100.0 / srcTotal, 1) : 0)%;"></div>
                                }
                            </div>
                            <div class="flex items-center gap-3 mt-1.5 text-xs text-gray-400">
                                <span class="text-green-600">@srcValid valid</span>
                                <span class="text-yellow-600">@src.WarningRows warn</span>
                                <span class="text-red-500">@src.ErrorRows err</span>
                                <span>@srcTotal total</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Common Validation Issues -->
        <div class="bg-white rounded-2xl shadow-sm p-8" style="border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #09637E;">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold" style="color: #09637E;">Common Issues</h3>
                    <p class="text-xs text-gray-400">Most frequent validation problems to address</p>
                </div>
            </div>

            @if (commonIssues != null && ((System.Collections.ICollection)commonIssues!).Count > 0)
            {
                <div class="space-y-3">
                    @{ var issueRank = 1; }
                    @foreach (var issue in (IEnumerable<dynamic>)commonIssues!)
                    {
                        <div class="flex items-start gap-3 py-3 border-b border-gray-100">
                            <span class="w-7 h-7 rounded-full bg-red-50 text-red-500 flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">@issueRank</span>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm text-gray-700 break-words">@issue.Message</p>
                                <p class="text-xs text-gray-400 mt-0.5">@issue.Count occurrences</p>
                            </div>
                        </div>
                        issueRank++;
                    }
                </div>
            }
            else
            {
                <div class="text-center py-8 text-gray-400">
                    <svg class="w-10 h-10 mx-auto mb-3 text-green-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <p class="text-sm font-medium">No validation issues detected</p>
                    <p class="text-xs mt-1">All records are passing validation cleanly.</p>
                </div>
            }
        </div>
    </div>

    <!-- Batch Quality Breakdown -->
    <div class="bg-white rounded-2xl shadow-sm p-8" style="border: 1px solid #7AB2B2;">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #7AB2B2;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">Batch Validation Detail</h3>
                <p class="text-xs text-gray-400">Per-batch cleansing results</p>
            </div>
        </div>

        @if (allBatches != null && allBatches.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b-2" style="border-color: #7AB2B2;">
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Batch ID</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Source</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Target</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Total</th>
                            <th class="text-center py-3 px-4 text-green-600 font-semibold">Valid</th>
                            <th class="text-center py-3 px-4 text-yellow-600 font-semibold">Warn</th>
                            <th class="text-center py-3 px-4 text-red-500 font-semibold">Error</th>
                            <th class="text-center py-3 px-4 text-gray-400 font-semibold">Pending</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Pulled At</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in allBatches)
                        {
                            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                                <td class="py-3 px-4 font-mono text-xs font-semibold text-gray-800">@b.BatchId</td>
                                <td class="py-3 px-4 text-gray-600">@b.DataSourceName</td>
                                <td class="py-3 px-4 font-mono text-xs text-gray-500">@b.TargetTable</td>
                                <td class="py-3 px-4 text-center font-semibold text-gray-800">@b.TotalRows</td>
                                <td class="py-3 px-4 text-center text-green-600 font-semibold">@b.ValidRows</td>
                                <td class="py-3 px-4 text-center text-yellow-600 font-semibold">@b.WarningRows</td>
                                <td class="py-3 px-4 text-center text-red-500 font-semibold">@b.ErrorRows</td>
                                <td class="py-3 px-4 text-center text-gray-400">@b.PendingRows</td>
                                <td class="py-3 px-4 text-gray-500 text-xs">@(((DateTime)b.PulledAt).ToString("MMM dd, yyyy hh:mm tt"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-12 text-gray-400">
                <p class="text-sm font-medium">No validation data yet</p>
                <p class="text-xs mt-1">Results appear after Staff pulls and validates data batches.</p>
            </div>
        }
    </div>
</div>
