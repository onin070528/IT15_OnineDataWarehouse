@using it15_webproject_mvc.Models
@{
    var logs = ViewData["AuditLogs"] as List<AuditLog> ?? new List<AuditLog>();
    var totalActions = (int)(ViewData["TotalActions"] ?? 0);
    var todayActions = (int)(ViewData["TodayActions"] ?? 0);
    var uniqueEntities = (int)(ViewData["UniqueEntities"] ?? 0);
    var uniqueUsers = (int)(ViewData["UniqueUsers"] ?? 0);
    var actionBreakdown = ViewData["ActionBreakdown"] as dynamic;
    var versionHistory = ViewData["VersionHistory"] as dynamic;
    var monthlyActivity = ViewData["MonthlyActivity"] as dynamic;
    var monthlyRecordsPulled = ViewData["MonthlyRecordsPulled"] as dynamic;
}

<div class="p-8 min-h-full" style="background-color: #EBF4F6;">

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-5 mb-8">
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-900">@totalActions</p>
                    <p class="text-xs text-gray-400">Total Actions</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #09637E;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-900">@todayActions</p>
                    <p class="text-xs text-gray-400">Today</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #7AB2B2;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-900">@uniqueEntities</p>
                    <p class="text-xs text-gray-400">Unique Entities</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm p-6" style="border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-900">@uniqueUsers</p>
                    <p class="text-xs text-gray-400">Active Contributors</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Action Breakdown -->
    @if (actionBreakdown != null && ((System.Collections.ICollection)actionBreakdown!).Count > 0)
    {
        <div class="bg-white rounded-2xl shadow-sm p-8 mb-8" style="border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold" style="color: #09637E;">Action Breakdown</h3>
                    <p class="text-sm text-gray-500">Distribution of actions across the warehouse</p>
                </div>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                @foreach (var item in (IEnumerable<dynamic>)actionBreakdown!)
                {
                    var barColor = (string)item.Action switch
                    {
                        "Source Added" => "bg-purple-500",
                        "Source Deleted" => "bg-red-500",
                        "Connection Tested" => "bg-sky-500",
                        "Data Pulled" => "bg-emerald-500",
                        "Batch Validated" => "bg-blue-500",
                        "Batch Submitted" => "bg-indigo-500",
                        _ => "bg-gray-400"
                    };

                    <div class="rounded-xl p-4" style="border: 1px solid #7AB2B2;">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-xs font-semibold text-gray-700">@item.Action</span>
                            <span class="text-sm font-bold text-gray-900">@item.Count</span>
                        </div>
                        <div class="w-full bg-gray-100 rounded-full h-1.5">
                            @{
                                var pct = totalActions > 0 ? Math.Min(100, (int)item.Count * 100 / totalActions) : 0;
                            }
                            <div class="@barColor h-1.5 rounded-full" style="width: @(pct)%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Version History + Monthly Trends -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">

        <!-- Data Version History -->
        @if (versionHistory != null && ((System.Collections.ICollection)versionHistory!).Count > 0)
        {
            <div class="bg-white rounded-2xl shadow-sm p-8" style="border: 1px solid #7AB2B2;">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold" style="color: #09637E;">Data Version History</h3>
                        <p class="text-xs text-gray-400">Dataset versioning across warehouse tables</p>
                    </div>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-gray-200">
                                <th class="text-left py-2 px-3 text-gray-500 font-semibold text-xs">Table</th>
                                <th class="text-left py-2 px-3 text-gray-500 font-semibold text-xs">Source</th>
                                <th class="text-center py-2 px-3 text-gray-500 font-semibold text-xs">Ver</th>
                                <th class="text-right py-2 px-3 text-gray-500 font-semibold text-xs">Active</th>
                                <th class="text-right py-2 px-3 text-gray-500 font-semibold text-xs">Archived</th>
                                <th class="text-left py-2 px-3 text-gray-500 font-semibold text-xs">Last Update</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in (IEnumerable<dynamic>)versionHistory!)
                            {
                                <tr class="border-b border-gray-100 hover:bg-gray-50">
                                    <td class="py-2.5 px-3 font-mono text-xs text-gray-700">@v.TargetTable</td>
                                    <td class="py-2.5 px-3 text-xs text-gray-600">@v.DataSourceName</td>
                                    <td class="py-2.5 px-3 text-center">
                                        <span class="text-xs font-bold px-2 py-0.5 rounded-full" style="background-color: #EBF4F6; color: #088395;">v@v.LatestVersion</span>
                                    </td>
                                    <td class="py-2.5 px-3 text-right text-green-600 font-semibold text-xs">@v.ActiveRecords</td>
                                    <td class="py-2.5 px-3 text-right text-gray-400 text-xs">@v.ArchivedRecords</td>
                                    <td class="py-2.5 px-3 text-xs text-gray-500">@(((DateTime)v.LastUpdated).ToString("MMM dd, yyyy"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Monthly Activity Trend -->
        @if (monthlyActivity != null && ((System.Collections.ICollection)monthlyActivity!).Count > 0)
        {
            <div class="bg-white rounded-2xl shadow-sm p-8" style="border: 1px solid #7AB2B2;">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #09637E;">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold" style="color: #09637E;">Activity Trend</h3>
                        <p class="text-xs text-gray-400">Monthly audit actions &amp; records pulled (last 6 months)</p>
                    </div>
                </div>
                <div class="space-y-3">
                    @{
                        var maxActivity = 1;
                        foreach (var m in (IEnumerable<dynamic>)monthlyActivity!) { if ((int)m.Count > maxActivity) maxActivity = (int)m.Count; }
                    }
                    @foreach (var m in (IEnumerable<dynamic>)monthlyActivity!)
                    {
                        var monthName = new DateTime((int)m.Year, (int)m.Month, 1).ToString("MMM yyyy");
                        var pctWidth = Math.Max(5, (int)m.Count * 100 / maxActivity);
                        <div class="flex items-center gap-3">
                            <span class="text-xs text-gray-500 w-20 text-right flex-shrink-0">@monthName</span>
                            <div class="flex-1 bg-gray-100 rounded-full h-5 relative overflow-hidden">
                                <div class="h-5 rounded-full flex items-center justify-end px-2" style="width: @(pctWidth)%; background-color: #088395;">
                                    <span class="text-xs text-white font-semibold">@m.Count</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (monthlyRecordsPulled != null && ((System.Collections.ICollection)monthlyRecordsPulled!).Count > 0)
                {
                    <h4 class="text-sm font-bold text-gray-700 mt-6 mb-3">Records Pulled</h4>
                    <div class="space-y-3">
                        @{
                            var maxPulled = 1;
                            foreach (var m in (IEnumerable<dynamic>)monthlyRecordsPulled!) { if ((int)m.Count > maxPulled) maxPulled = (int)m.Count; }
                        }
                        @foreach (var m in (IEnumerable<dynamic>)monthlyRecordsPulled!)
                        {
                            var monthName = new DateTime((int)m.Year, (int)m.Month, 1).ToString("MMM yyyy");
                            var pctWidth = Math.Max(5, (int)m.Count * 100 / maxPulled);
                            <div class="flex items-center gap-3">
                                <span class="text-xs text-gray-500 w-20 text-right flex-shrink-0">@monthName</span>
                                <div class="flex-1 bg-gray-100 rounded-full h-5 relative overflow-hidden">
                                    <div class="h-5 rounded-full flex items-center justify-end px-2" style="width: @(pctWidth)%; background-color: #7AB2B2;">
                                        <span class="text-xs text-white font-semibold">@m.Count</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <!-- Full Audit Log -->
    <div class="bg-white rounded-2xl shadow-sm p-8" style="border: 1px solid #7AB2B2;">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #09637E;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">Complete Audit Trail</h3>
                <p class="text-sm text-gray-500">Full history of all warehouse actions (most recent first)</p>
            </div>
        </div>

        @if (logs.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200">
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Date &amp; Time</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">User</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Action</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Entity</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Name / ID</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in logs)
                        {
                            var actionColor = log.Action switch
                            {
                                "Source Added" => "text-purple-600 bg-purple-50",
                                "Source Deleted" => "text-red-600 bg-red-50",
                                "Connection Tested" => "text-sky-600 bg-sky-50",
                                "Data Pulled" => "text-emerald-600 bg-emerald-50",
                                "Batch Validated" => "text-blue-600 bg-blue-50",
                                "Batch Submitted" => "text-indigo-600 bg-indigo-50",
                                _ => "text-gray-600 bg-gray-50"
                            };

                            var actionIcon = log.Action switch
                            {
                                "Source Added" => "+",
                                "Source Deleted" => "ū",
                                "Connection Tested" => "?",
                                "Data Pulled" => "?",
                                "Batch Validated" => "?",
                                "Batch Submitted" => "??",
                                _ => "Ģ"
                            };

                            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                                <td class="py-3 px-4 text-gray-500 text-xs whitespace-nowrap">
                                    @log.Performed_at.ToString("MMM dd, yyyy")<br />
                                    <span class="text-gray-400">@log.Performed_at.ToString("hh:mm:ss tt")</span>
                                </td>
                                <td class="py-3 px-4">
                                    <div class="flex items-center gap-2">
                                        <span class="inline-flex items-center justify-center w-7 h-7 rounded-full text-white text-xs font-bold flex-shrink-0" style="background-color: #088395;">
                                            @(log.PerformedByUser?.Full_name?.Substring(0, Math.Min(2, log.PerformedByUser?.Full_name?.Length ?? 0)).ToUpper() ?? "??")
                                        </span>
                                        <span class="text-sm font-medium text-gray-700">@(log.PerformedByUser?.Full_name ?? "Unknown")</span>
                                    </div>
                                </td>
                                <td class="py-3 px-4 text-center">
                                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full @actionColor">
                                        @actionIcon @log.Action
                                    </span>
                                </td>
                                <td class="py-3 px-4 text-gray-500 text-xs">
                                    <span class="px-2 py-0.5 rounded bg-gray-100 font-mono">@log.EntityType</span>
                                </td>
                                <td class="py-3 px-4 text-gray-800 text-xs font-semibold">
                                    @(log.EntityName ?? "Ś")
                                    @if (log.EntityId.HasValue)
                                    {
                                        <span class="text-gray-400 font-normal ml-1">#@log.EntityId</span>
                                    }
                                </td>
                                <td class="py-3 px-4 text-xs text-gray-500 max-w-xs">
                                    <span class="truncate block max-w-[300px]" title="@log.Details">@(log.Details ?? "Ś")</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (logs.Count >= 100)
            {
                <div class="text-center mt-6">
                    <p class="text-xs text-gray-400">Showing the most recent 100 entries out of @totalActions total.</p>
                </div>
            }
        }
        else
        {
            <div class="text-center py-12 text-gray-400">
                <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-sm font-medium">No historical data recorded yet</p>
                <p class="text-xs mt-1">Actions performed across the warehouse will appear here automatically.</p>
            </div>
        }
    </div>
</div>
