@using it15_webproject_mvc.Models
@{
    var section = (ViewData["Section"] as string ?? "dashboard").ToLower();
    var orgUsers = ViewData["OrgUsers"] as List<User> ?? new List<User>();
    var subPlan = ViewData["SubscriptionPlan"] as string ?? "Free";
}

@if (section == "users")
{
    <!-- MANAGE USERS -->
    <div class="p-8 bg-gray-100 min-h-full">

        @if (TempData["Success"] != null)
        {
            <div id="successToast" class="mb-4 flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-lg shadow-sm">
                <span class="w-5 h-5 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center text-xs flex-shrink-0">✓</span>
                <span class="text-sm font-medium">@TempData["Success"]</span>
                <button onclick="document.getElementById('successToast').remove()" class="ml-auto text-emerald-400 hover:text-emerald-600">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div id="errorToast" class="mb-4 flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg shadow-sm">
                <span class="w-5 h-5 rounded-full bg-red-100 text-red-600 flex items-center justify-center text-xs flex-shrink-0">✗</span>
                <span class="text-sm font-medium">@TempData["Error"]</span>
                <button onclick="document.getElementById('errorToast').remove()" class="ml-auto text-red-400 hover:text-red-600">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
        }

        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h3 class="text-lg font-bold text-gray-900">User Management</h3>
                    <p class="text-sm text-gray-500 mt-1">Add, edit, or deactivate data warehouse users</p>
                </div>
                <div class="flex items-center gap-3">
                    <input type="text" placeholder="Search users..."
                           class="px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2" onfocus="this.style.boxShadow='0 0 0 2px #7AB2B2'" onblur="this.style.boxShadow=''" />
                    <button onclick="document.getElementById('addUserModal').classList.remove('hidden')"
                            class="px-4 py-2 text-white rounded-lg text-sm font-semibold transition-colors" style="background-color: #088395;" onmouseover="this.style.backgroundColor='#09637E'" onmouseout="this.style.backgroundColor='#088395'">
                        + Add User
                    </button>
                </div>
            </div>

            <!-- ADD USER MODAL -->
            <div id="addUserModal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
                <!-- Backdrop -->
                <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"
                     onclick="document.getElementById('addUserModal').classList.add('hidden')"></div>

                <!-- Modal Content -->
                <div class="relative bg-white rounded-2xl shadow-2xl border border-gray-200 w-full max-w-lg mx-4 max-h-[90vh] overflow-y-auto">
                    <!-- Header -->
                    <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
                        <div class="flex items-center gap-3">
                            <span class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #EBF4F6; color: #088395;">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                                </svg>
                            </span>
                            <div>
                                <h3 class="text-lg font-bold text-gray-900">Add New User</h3>
                                <p class="text-xs text-gray-500">Create a new user under your organization</p>
                            </div>
                        </div>
                        <button onclick="document.getElementById('addUserModal').classList.add('hidden')"
                                class="w-8 h-8 rounded-lg flex items-center justify-center text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M6 18L18 6M6 6l12 12"/>
                            </svg>
                        </button>
                    </div>

                    <!-- Form Body -->
                    <form method="post" action="@Url.Action("AddUser", "UserAdmin")" class="p-6 space-y-5">
                        @Html.AntiForgeryToken()

                        <!-- Full Name -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                Full Name <span class="text-red-500">*</span>
                            </label>
                            <input name="fullName"
                                   type="text"
                                   maxlength="25"
                                   required
                                   placeholder="e.g. Juan Dela Cruz"
                                   class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 transition" onfocus="this.style.boxShadow='0 0 0 2px #7AB2B2'" onblur="this.style.boxShadow=''" />
                        </div>

                        <!-- Username -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                Username <span class="text-red-500">*</span>
                            </label>
                            <input name="username"
                                   type="text"
                                   maxlength="15"
                                   required
                                   placeholder="e.g. jdelacruz"
                                   class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 transition" onfocus="this.style.boxShadow='0 0 0 2px #7AB2B2'" onblur="this.style.boxShadow=''" />
                        </div>

                        <!-- Email -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                Email Address <span class="text-red-500">*</span>
                            </label>
                            <input name="email"
                                   type="email"
                                   maxlength="30"
                                   required
                                   placeholder="e.g. juan@company.com"
                                   class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 transition" onfocus="this.style.boxShadow='0 0 0 2px #7AB2B2'" onblur="this.style.boxShadow=''" />
                        </div>

                        <!-- Role -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                Assign Role <span class="text-red-500">*</span>
                            </label>
                            <select name="role"
                                    required
                                    class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 transition" onfocus="this.style.boxShadow='0 0 0 2px #7AB2B2'" onblur="this.style.boxShadow=''">
                                <option value="" disabled selected>Select a role...</option>
                                <option value="Staff">Staff — Data operations</option>
                                @if (subPlan == "Basic" || subPlan == "Premium")
                                {
                                    <option value="Manager">Manager — Oversight & approvals</option>
                                }
                                @if (subPlan == "Premium")
                                {
                                    <option value="DataAnalyst">Data Analyst — Security & ETL oversight</option>
                                }
                            </select>
                            @if (subPlan == "Free")
                            {
                                <p class="text-xs text-amber-600 mt-1">🔒 Free plan: Staff role only. <a href="@Url.Action("UserNav", "UserAdmin", new { section = "subscription" })" class="underline font-semibold">Upgrade</a> for more roles.</p>
                            }
                            else if (subPlan == "Basic")
                            {
                                <p class="text-xs text-gray-400 mt-1">📦 Basic plan: Staff & Manager roles. <a href="@Url.Action("UserNav", "UserAdmin", new { section = "subscription" })" class="underline font-semibold" style="color: #088395;">Upgrade to Premium</a> for Data Analyst.</p>
                            }
                        </div>

                        <!-- Password -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                Password <span class="text-red-500">*</span>
                            </label>
                            <div class="relative">
                                <input id="addUserPassword"
                                       name="password"
                                       type="password"
                                       minlength="12"
                                       pattern="^(?=.*[^a-zA-Z0-9]).{12,}$"
                                       title="Password must be at least 12 characters and contain at least one special character."
                                       required
                                       placeholder="Minimum 12 characters with a special character"
                                       class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 transition pr-10" onfocus="this.style.boxShadow='0 0 0 2px #7AB2B2'" onblur="this.style.boxShadow=''" />
                                <button type="button"
                                        onclick="var el=document.getElementById('addUserPassword'); el.type=el.type==='password'?'text':'password';"
                                        class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        <path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <!-- Confirm Password -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                Confirm Password <span class="text-red-500">*</span>
                            </label>
                            <div class="relative">
                                <input id="addUserConfirmPassword"
                                       name="confirmPassword"
                                       type="password"
                                       minlength="12"
                                       pattern="^(?=.*[^a-zA-Z0-9]).{12,}$"
                                       title="Password must be at least 12 characters and contain at least one special character."
                                       required
                                       placeholder="Re-enter password"
                                       class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 transition pr-10" onfocus="this.style.boxShadow='0 0 0 2px #7AB2B2'" onblur="this.style.boxShadow=''" />
                                <button type="button"
                                        onclick="var el=document.getElementById('addUserConfirmPassword'); el.type=el.type==='password'?'text':'password';"
                                        class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        <path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <!-- Account Status -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                Account Status
                            </label>
                            <select name="accountStatus"
                                    class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 transition" onfocus="this.style.boxShadow='0 0 0 2px #7AB2B2'" onblur="this.style.boxShadow=''">
                                <option value="Active" selected>Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                        </div>

                        <!-- Info Badge -->
                        <div class="rounded-lg px-4 py-3" style="background-color: #EBF4F6; border: 1px solid #7AB2B2;">
                            <div class="flex items-center gap-3">
                                <span class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #EBF4F6; color: #088395;">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                </span>
                                <div>
                                    <p class="text-xs font-semibold" style="color: #09637E;">User will be added to your organization</p>
                                    <p class="text-xs" style="color: #088395;">They can log in immediately with the credentials you set</p>
                                </div>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="flex items-center justify-end gap-3 pt-2">
                            <button type="button"
                                    onclick="document.getElementById('addUserModal').classList.add('hidden')"
                                    class="px-5 py-2.5 rounded-lg border border-gray-300 text-gray-700 text-sm font-semibold hover:bg-gray-50 transition-colors">
                                Cancel
                            </button>
                            <button type="submit"
                                    class="px-5 py-2.5 rounded-lg text-white text-sm font-semibold transition-colors shadow-sm" style="background-color: #088395;" onmouseover="this.style.backgroundColor='#09637E'" onmouseout="this.style.backgroundColor='#088395'">
                                Create User
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200">
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">User</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Email</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Role</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Organization</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Last Login</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Status</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (orgUsers.Any())
                        {
                            @foreach (var u in orgUsers)
                            {
                                var initials = u.Full_name.Length >= 2 ? u.Full_name.Substring(0, 2).ToUpper() : u.Full_name.ToUpper();
                                var roleName = u.Role?.RoleName ?? "Staff";
                                var orgNameDisplay = u.Organization?.OrganizationName ?? "—";
                                var statusColor = u.Account_status == "Active" ? "green" : "gray";
                                var lastLoginDisplay = u.Last_login.HasValue
                                    ? u.Last_login.Value.ToString("MMM dd, yyyy hh:mm tt")
                                    : "Never";

                                <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                                    <td class="py-3 px-4">
                                        <div class="flex items-center gap-3">
                                            <span class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0" style="background-color: #EBF4F6; color: #088395;">
                                                @initials
                                            </span>
                                            <span class="font-semibold text-gray-800">@u.Full_name</span>
                                        </div>
                                    </td>
                                    <td class="py-3 px-4 text-gray-600">@u.Email</td>
                                    <td class="py-3 px-4">
                                        <span class="text-xs font-semibold px-2 py-1 rounded-full" style="background-color: #EBF4F6; color: #088395;">@roleName</span>
                                    </td>
                                    <td class="py-3 px-4 text-gray-600">@orgNameDisplay</td>
                                    <td class="py-3 px-4 text-gray-500">@lastLoginDisplay</td>
                                    <td class="py-3 px-4 text-center">
                                        <span class="text-xs font-medium px-2.5 py-1 rounded-full
                                            @(statusColor == "green" ? "text-green-600 bg-green-50" : "text-gray-500 bg-gray-100")">
                                            @u.Account_status
                                        </span>
                                    </td>
                                    <td class="py-3 px-4 text-center">
                                        <div class="flex items-center justify-center gap-2">
                                            <button class="hover:opacity-80" style="color: #088395;" title="Edit">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                    <path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                                </svg>
                                            </button>
                                            <button class="text-red-500 hover:text-red-700" title="Deactivate">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                    <path d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
                                                </svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="py-8 text-center text-gray-400 text-sm">No users found in your organization.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else if (section == "subscription")
{
    <!-- SUBSCRIPTION PLANS -->
    <div class="p-8 bg-gray-100 min-h-full">

        @if (TempData["Success"] != null)
        {
            <div id="paySuccessToast" class="mb-4 flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-lg shadow-sm">
                <span class="w-5 h-5 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center text-xs flex-shrink-0">✓</span>
                <span class="text-sm font-medium">@TempData["Success"]</span>
                <button onclick="document.getElementById('paySuccessToast').remove()" class="ml-auto text-emerald-400 hover:text-emerald-600">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div id="payErrorToast" class="mb-4 flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg shadow-sm">
                <span class="w-5 h-5 rounded-full bg-red-100 text-red-600 flex items-center justify-center text-xs flex-shrink-0">✗</span>
                <span class="text-sm font-medium">@TempData["Error"]</span>
                <button onclick="document.getElementById('payErrorToast').remove()" class="ml-auto text-red-400 hover:text-red-600">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
        }

        <!-- Current Plan Badge -->
        <div class="mb-6 rounded-lg px-4 py-3" style="background-color: #EBF4F6; border: 1px solid #7AB2B2;">
            <div class="flex items-center gap-3">
                <svg class="w-5 h-5 flex-shrink-0" style="color: #088395;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-sm" style="color: #09637E;">
                    Your current plan: <strong>@subPlan</strong>
                    @if (subPlan == "Free") { <span>— Upgrade to unlock more features and roles.</span> }
                    else if (subPlan == "Basic") { <span>— Upgrade to Premium for full access.</span> }
                    else { <span>— You have full access to all features.</span> }
                </p>
            </div>
        </div>

        <!-- Header -->
        <div class="mb-8 text-center">
            <h2 class="text-2xl font-bold text-gray-900">Choose Your Plan</h2>
            <p class="text-gray-500 mt-2">Select the data warehouse access tier that fits your needs.</p>
        </div>

        <!-- Plan Cards -->
        <div class="flex flex-col lg:flex-row items-stretch justify-center gap-6 max-w-5xl mx-auto">

            <!-- FREE PLAN -->
            <div class="flex-1 bg-white rounded-2xl border-2 shadow-sm p-7 flex flex-col transition-all duration-300 hover:shadow-xl hover:-translate-y-1 cursor-pointer @(subPlan == "Free" ? "border-green-400" : "border-gray-200")" onmouseover="this.style.borderColor='#7AB2B2'" onmouseout="this.style.borderColor='@(subPlan == "Free" ? "#4ade80" : "")'">
                <div class="mb-5">
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-green-50 text-green-600 text-xs font-bold uppercase tracking-wider">
                        🆓 Free
                    </span>
                    @if (subPlan == "Free")
                    {
                        <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full bg-green-100 text-green-700 text-[10px] font-bold uppercase">Current</span>
                    }
                </div>
                <div class="mb-5">
                    <p class="text-4xl font-extrabold text-gray-900">₱0<span class="text-lg font-normal text-gray-400">/mo</span></p>
                    <p class="text-sm text-gray-400 mt-1">Free forever</p>
                </div>
                <hr class="border-gray-100 mb-5" />
                <ul class="space-y-2.5 text-sm text-gray-600 flex-1">
                    <li class="flex items-center gap-2.5">
                        <span class="w-5 h-5 rounded-full bg-green-50 text-green-500 flex items-center justify-center text-xs flex-shrink-0">✓</span>
                        UserAdmin + Staff roles
                    </li>
                    <li class="flex items-center gap-2.5">
                        <span class="w-5 h-5 rounded-full bg-green-50 text-green-500 flex items-center justify-center text-xs flex-shrink-0">✓</span>
                        Up to 3 users
                    </li>
                    <li class="flex items-center gap-2.5">
                        <span class="w-5 h-5 rounded-full bg-green-50 text-green-500 flex items-center justify-center text-xs flex-shrink-0">✓</span>
                        1 API data source
                    </li>
                    <li class="flex items-center gap-2.5">
                        <span class="w-5 h-5 rounded-full bg-green-50 text-green-500 flex items-center justify-center text-xs flex-shrink-0">✓</span>
                        Basic dashboard
                    </li>
                    <li class="flex items-center gap-2.5">
                        <span class="w-5 h-5 rounded-full bg-green-50 text-green-500 flex items-center justify-center text-xs flex-shrink-0">✓</span>
                        Last 20 activity logs
                    </li>
                    <li class="flex items-center gap-2.5 text-gray-300">
                        <span class="w-5 h-5 rounded-full bg-gray-50 flex items-center justify-center text-xs flex-shrink-0">✗</span>
                        Data Warehouse modules
                    </li>
                    <li class="flex items-center gap-2.5 text-gray-300">
                        <span class="w-5 h-5 rounded-full bg-gray-50 flex items-center justify-center text-xs flex-shrink-0">✗</span>
                        Manager role
                    </li>
                    <li class="flex items-center gap-2.5 text-gray-300">
                        <span class="w-5 h-5 rounded-full bg-gray-50 flex items-center justify-center text-xs flex-shrink-0">✗</span>
                        Data Analyst role
                    </li>
                </ul>
                <div class="mt-6">
                    @if (subPlan == "Free")
                    {
                        <span class="block w-full py-3 rounded-xl border-2 border-green-300 text-green-600 font-semibold text-sm text-center">✓ Current Plan</span>
                    }
                    else
                    {
                        <span class="block w-full py-3 rounded-xl border-2 border-gray-200 text-gray-400 font-semibold text-sm text-center">Included</span>
                    }
                </div>
            </div>

            <!-- BASIC PLAN -->
