                            <td class="py-2.5 px-4 text-center font-semibold" style="color: #088395;">Unlimited</td>
                        </tr>
                        <tr class="border-b border-gray-100">
                            <td class="py-2.5 px-4 text-gray-600">Data Source Integration</td>
                            <td class="py-2.5 px-4 text-center text-gray-400">✗</td>
                            <td class="py-2.5 px-4 text-center text-green-500 font-bold">✓</td>
                            <td class="py-2.5 px-4 text-center text-green-500 font-bold">✓</td>
                        </tr>
                        <tr class="border-b border-gray-100">
                            <td class="py-2.5 px-4 text-gray-600">ETL Pipeline</td>
                            <td class="py-2.5 px-4 text-center text-gray-400">✗</td>
                            <td class="py-2.5 px-4 text-center text-green-500 font-bold">✓</td>
                            <td class="py-2.5 px-4 text-center text-green-500 font-bold">✓</td>
                        </tr>
                        <tr class="border-b border-gray-100">
                            <td class="py-2.5 px-4 text-gray-600">Centralized Data Storage</td>
                            <td class="py-2.5 px-4 text-center text-gray-400">✗</td>
                            <td class="py-2.5 px-4 text-center text-gray-400">✗</td>
                            <td class="py-2.5 px-4 text-center text-green-500 font-bold">✓</td>
