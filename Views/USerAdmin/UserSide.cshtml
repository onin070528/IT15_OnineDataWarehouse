}
else if (section == "roles")
{
    <!-- ROLES & PERMISSIONS -->
    <div class="p-8 bg-gray-100 min-h-full">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 mb-8">
            <div class="mb-6">
                <h3 class="text-lg font-bold text-gray-900">Roles & Permissions</h3>
                <p class="text-sm text-gray-500 mt-1">Overview of warehouse access levels and what each role does</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                @{
                    var roleDefinitions = new[] {
                        ("Admin", "Organization admin — user & subscription management", "users",
                            new[] {
                                ("Add, edit & deactivate org users", true),
                                ("Assign roles to team members", true),
                                ("Manage subscription & payments", true),
                                ("Toggle data source Active/Inactive", true),
                                ("Archive & restore warehouse tables", true),
                                ("View data sources, ETL, storage & cleansing", true),
                                ("View activity logs", true),
                                ("No direct data pull, validate or submit", false)
                            }),
                        ("DataAnalyst", "Read-only oversight — security, ETL & data quality", "chart",
                            new[] {
                                ("Monitor user security & login activity", true),
                                ("View all data sources & ETL pipelines", true),
                                ("Query & browse warehouse table data", true),
                                ("Analyze data cleansing & quality metrics", true),
                                ("View version history & audit trends", true),
                                ("No data modifications or approvals", false)
                            }),
                        ("Manager", "Approval gate — reviews & loads data into warehouse", "briefcase",
                            new[] {
                                ("Approve or reject submitted batches", true),
                                ("Load approved data into warehouse (Append/Overwrite/Upsert)", true),
                                ("Preview submission data before approval", true),
                                ("View reports, performance & team activity", true),
                                ("Export submission data", true),
                                ("View audit logs & version history", true),
                                ("No data pull, validate or source config", false)
                            }),
                        ("Staff", "Data operations — extract, validate & submit data", "user",
                            new[] {
                                ("Configure API data sources (add, test, delete)", true),
                                ("Pull data from APIs into staging", true),
                                ("Validate & correct staging records", true),
                                ("Submit verified batches for manager approval", true),
                                ("View reports & dashboard metrics", true),
                                ("View activity history", true),
                                ("No approval or warehouse write access", false)
                            })
                    };
                }
                @foreach (var (roleName, desc, icon, perms) in roleDefinitions)
                {
                    var userCount = orgUsers.Count(u => u.Role?.RoleName == roleName);
                    var countLabel = userCount == 1 ? "1 user" : $"{userCount} users";

                    <div class="border border-gray-200 rounded-xl p-5 hover:shadow-sm transition-all" onmouseover="this.style.borderColor='#7AB2B2'" onmouseout="this.style.borderColor=''">
                        <div class="flex items-center justify-between mb-3">
                            <h4 class="text-sm font-bold text-gray-900">@roleName</h4>
                            <span class="text-xs font-medium px-2 py-0.5 rounded-full" style="background-color: #EBF4F6; color: #088395;">@countLabel</span>
                        </div>
                        <p class="text-xs text-gray-500 mb-4">@desc</p>
                        <div class="space-y-1.5">
                            @foreach (var (perm, isEnabled) in perms)
                            {
                                <div class="flex items-center gap-2 text-xs @(isEnabled ? "text-gray-600" : "text-gray-400")">
                                    <span class="@(isEnabled ? "text-green-500" : "text-gray-300")">@(isEnabled ? "✓" : "✗")</span>
                                    @perm
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
else
{
    <!-- Fallback - redirect to dashboard -->
    <div class="p-8 bg-gray-100 min-h-full">
        <div class="text-center py-12 text-gray-400">
            <p class="text-sm">This section is not available here.</p>
        </div>
    </div>
}
