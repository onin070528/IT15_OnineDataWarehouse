        @if (payments.Any())
        {
            <div class="max-w-5xl mx-auto mt-6 bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
                <h4 class="text-sm font-bold text-gray-900 mb-4">Payment History</h4>
