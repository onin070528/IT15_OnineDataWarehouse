@using System.Security.Claims
@{
    var orgName = ViewData["OrganizationName"] as string ?? "My Company";
    ViewData["Title"] = orgName + " - Data Warehouse";
    var section = (ViewData["Section"] as string ?? "dashboard").ToLower();
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "UserAdmin";
    var subPlan = ViewData["SubscriptionPlan"] as string ?? "Free";
    var isBasicOrAbove = subPlan == "Basic" || subPlan == "Premium";
    var isPremium = subPlan == "Premium";
}

<div class="flex min-h-screen bg-gray-100">

<!-- MOBILE OVERLAY -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

<!-- SIDEBAR -->
<aside class="app-sidebar w-60 bg-white border-r border-gray-200 flex flex-col justify-between fixed top-0 left-0 h-full z-40" id="appSidebar">
        <!-- Logo -->
        <div>
            <div class="px-6 py-5 border-b border-gray-100">
                <div class="flex items-center gap-2">
                    <span class="text-lg font-bold truncate" style="color: #088395;" title="@orgName">@orgName</span>
                </div>
            </div>

            <!-- Navigation Links -->
            <nav class="mt-6 px-4 space-y-1">
                <a href="@Url.Action("UserNav", "UserAdmin", new { section = "dashboard" })"
                   class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium no-underline transition-colors
                       @(section == "dashboard" ? "text-gray-900" : "text-gray-500 hover:bg-gray-50 hover:text-gray-800")" style="@(section == "dashboard" ? "background-color: #EBF4F6;" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                    </svg>
                    Dashboard
                </a>
                <a href="@Url.Action("UserNav", "UserAdmin", new { section = "users" })"
                   class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium no-underline transition-colors
                       @(section == "users" ? "text-gray-900" : "text-gray-500 hover:bg-gray-50 hover:text-gray-800")" style="@(section == "users" ? "background-color: #EBF4F6;" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                    Manage Users
                </a>
                <a href="@Url.Action("UserNav", "UserAdmin", new { section = "roles" })"
                   class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium no-underline transition-colors
                       @(section == "roles" ? "text-gray-900" : "text-gray-500 hover:bg-gray-50 hover:text-gray-800")" style="@(section == "roles" ? "background-color: #EBF4F6;" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                    </svg>
                    Roles & Permissions
                </a>
                <a href="@Url.Action("UserNav", "UserAdmin", new { section = "subscription" })"
                   class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium no-underline transition-colors
                       @(section == "subscription" ? "text-gray-900" : "text-gray-500 hover:bg-gray-50 hover:text-gray-800")" style="@(section == "subscription" ? "background-color: #EBF4F6;" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                    </svg>
                    Subscription
                </a>
                <a href="@Url.Action("UserNav", "UserAdmin", new { section = "logs" })"
                   class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium no-underline transition-colors
                       @(section == "logs" ? "text-gray-900" : "text-gray-500 hover:bg-gray-50 hover:text-gray-800")" style="@(section == "logs" ? "background-color: #EBF4F6;" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
                    </svg>
                    Activity Logs
                </a>

                <!-- Data Warehouse Modules -->
                @if (isBasicOrAbove)
                {
                <div class="pt-4 mt-4 border-t border-gray-200">
                    <p class="px-4 text-[10px] font-bold uppercase tracking-wider text-gray-400 mb-2">Data Warehouse</p>
                </div>

                <a href="@Url.Action("UserNav", "UserAdmin", new { section = "datasources" })"
                   class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium no-underline transition-colors
                       @(section == "datasources" ? "text-gray-900" : "text-gray-500 hover:bg-gray-50 hover:text-gray-800")" style="@(section == "datasources" ? "background-color: #EBF4F6;" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                    </svg>
                    Data Sources
                </a>
                <a href="@Url.Action("UserNav", "UserAdmin", new { section = "etl" })"
                   class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium no-underline transition-colors
                       @(section == "etl" ? "text-gray-900" : "text-gray-500 hover:bg-gray-50 hover:text-gray-800")" style="@(section == "etl" ? "background-color: #EBF4F6;" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                    </svg>
                    ETL Pipeline
                </a>
                    @if (isPremium)
                    {
                <a href="@Url.Action("UserNav", "UserAdmin", new { section = "storage" })"
                   class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium no-underline transition-colors
                       @(section == "storage" ? "text-gray-900" : "text-gray-500 hover:bg-gray-50 hover:text-gray-800")" style="@(section == "storage" ? "background-color: #EBF4F6;" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>
                    </svg>
                    Data Storage
                </a>
                <a href="@Url.Action("UserNav", "UserAdmin", new { section = "cleansing" })"
                   class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium no-underline transition-colors
                       @(section == "cleansing" ? "text-gray-900" : "text-gray-500 hover:bg-gray-50 hover:text-gray-800")" style="@(section == "cleansing" ? "background-color: #EBF4F6;" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Data Cleansing
                </a>
                    }
                }
            </nav>
        </div>

        <!-- User Profile + Logout -->
        <div class="px-4 pb-5">
            <hr class="mb-4 border-gray-200" />
            <!-- Subscription Badge -->
            <div class="px-2 mb-3">
                @if (subPlan == "Premium")
                {
                    <span class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-bold w-full justify-center" style="background: linear-gradient(135deg, #088395, #09637E); color: white;">
                        ⭐ Premium Plan
                    </span>
                }
                else if (subPlan == "Basic")
                {
                    <span class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-bold w-full justify-center" style="background-color: #EBF4F6; color: #088395;">
                        📦 Basic Plan
                    </span>
                }
                else
                {
                    <a href="@Url.Action("UserNav", "UserAdmin", new { section = "subscription" })"
                       class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-bold w-full justify-center no-underline bg-amber-50 text-amber-700 hover:bg-amber-100 transition-colors">
                        🔓 Free Plan — Upgrade
                    </a>
                }
            </div>
            <div class="flex items-center gap-3 px-2 mb-3">
                <span class="inline-flex items-center justify-center w-9 h-9 rounded-full text-white text-xs font-bold flex-shrink-0" style="background-color: #088395;">
                    @(User.Identity?.Name?.Substring(0, Math.Min(2, User.Identity?.Name?.Length ?? 0)).ToUpper() ?? "AD")
                </span>
                <div class="overflow-hidden">
                    <p class="text-sm font-semibold text-gray-800 truncate">@User.Identity?.Name</p>
                    <p class="text-xs text-gray-400 truncate">@userRole</p>
                </div>
            </div>
            <a href="/auth/logout"
               class="flex items-center justify-center gap-2 w-full px-4 py-2.5 bg-red-500 text-white rounded-lg text-sm font-semibold hover:bg-red-600 transition-colors no-underline">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
                Logout
            </a>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <div class="app-main flex-1 ml-60">
        <!-- Top Bar -->
        <header class="bg-white border-b border-gray-200 px-4 md:px-8 py-4 md:py-5 flex items-center justify-between sticky top-0 z-30">
            <!-- Mobile hamburger -->
            <button class="mobile-menu-btn items-center justify-center w-10 h-10 rounded-lg text-gray-600 hover:bg-gray-100 mr-3" onclick="toggleSidebar()" style="display:none;">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
            </button>
            <h1 class="text-lg md:text-2xl font-bold text-gray-900 truncate">
                @(section switch
                {
                    "users" => "Manage Users",
                    "roles" => "Roles & Permissions",
                    "subscription" => "Subscription",
                    "logs" => "Activity Logs",
                    "datasources" => "Data Source Integration",
                    "etl" => "ETL Pipeline",
                    "storage" => "Centralized Data Storage",
                    "cleansing" => "Data Cleansing",
                    _ => "Dashboard"
                })
            </h1>
            <div class="flex items-center gap-3">
                <partial name="_NotificationBell" />
            </div>
        </header>

        <!-- Page Content -->
        <main class="p-0">
            @if (section == "users")
            {
                <partial name="UserSide" />
            }
            else if (section == "roles")
            {
                <partial name="UserSide" />
            }
            else if (section == "subscription")
            {
                <partial name="UserSide" />
            }
            else if (section == "logs")
            {
                <partial name="UserHistory" />
            }
            else if (section == "datasources")
            {
                <partial name="UserDataSources" />
            }
            else if (section == "etl")
            {
                <partial name="UserETL" />
            }
            else if (section == "storage")
            {
                <partial name="UserStorage" />
            }
            else if (section == "cleansing")
            {
                <partial name="UserCleansing" />
            }
            else
            {
                <partial name="UserIndex" />
            }
        </main>
    </div>

</div>

<script>
    function toggleSidebar() {
        document.getElementById('appSidebar').classList.toggle('open');
        document.getElementById('sidebarOverlay').classList.toggle('active');
    }
</script>
