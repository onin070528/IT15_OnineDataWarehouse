@{
    var allBatches = ViewData["AllBatches"] as IEnumerable<dynamic>;
    var totalRows = (int)(ViewData["TotalRows"] ?? 0);
    var validRows = (int)(ViewData["ValidRows"] ?? 0);
    var errorRows = (int)(ViewData["ErrorRows"] ?? 0);
    var warningRows = (int)(ViewData["WarningRows"] ?? 0);
    var pendingRows = (int)(ViewData["PendingRows"] ?? 0);
    var successRate = (double)(ViewData["SuccessRate"] ?? 0.0);
}

<div class="p-8 bg-gray-100 min-h-full">

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-5 mb-8">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <p class="text-2xl font-bold" style="color: #09637E;">@totalRows.ToString("N0")</p>
            <p class="text-xs text-gray-400 mt-1">Total Rows</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <p class="text-2xl font-bold text-green-600">@validRows.ToString("N0")</p>
            <p class="text-xs text-gray-400 mt-1">Valid</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <p class="text-2xl font-bold text-yellow-600">@warningRows.ToString("N0")</p>
            <p class="text-xs text-gray-400 mt-1">Warnings</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <p class="text-2xl font-bold text-red-500">@errorRows.ToString("N0")</p>
            <p class="text-xs text-gray-400 mt-1">Errors</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <p class="text-2xl font-bold" style="color: #088395;">@successRate%</p>
            <p class="text-xs text-gray-400 mt-1">Success Rate</p>
        </div>
    </div>

    <!-- Read-only notice -->
    <div class="rounded-lg px-4 py-3 mb-6" style="background-color: #EBF4F6; border: 1px solid #7AB2B2;">
        <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" style="color: #088395;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-xs" style="color: #09637E;"><strong>Read-only view.</strong> Data validation is performed by Staff in the Verify Data section.</p>
        </div>
    </div>

    <!-- Validation quality bar -->
    @if (totalRows > 0)
    {
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 mb-8">
            <h4 class="text-sm font-bold text-gray-900 mb-3">Data Quality Overview</h4>
            <div class="flex w-full rounded-full h-4 overflow-hidden bg-gray-100">
                @if (validRows > 0)
                {
                    <div class="bg-green-500 h-4" style="width: @(Math.Round(validRows * 100.0 / totalRows, 1))%;" title="Valid: @validRows"></div>
                }
                @if (warningRows > 0)
                {
                    <div class="bg-yellow-400 h-4" style="width: @(Math.Round(warningRows * 100.0 / totalRows, 1))%;" title="Warnings: @warningRows"></div>
                }
                @if (errorRows > 0)
                {
                    <div class="bg-red-500 h-4" style="width: @(Math.Round(errorRows * 100.0 / totalRows, 1))%;" title="Errors: @errorRows"></div>
                }
                @if (pendingRows > 0)
                {
                    <div class="bg-gray-300 h-4" style="width: @(Math.Round(pendingRows * 100.0 / totalRows, 1))%;" title="Pending: @pendingRows"></div>
                }
            </div>
            <div class="flex items-center gap-6 mt-3 text-xs text-gray-500">
                <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-green-500"></span> Valid (@validRows)</span>
                <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-yellow-400"></span> Warning (@warningRows)</span>
                <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-500"></span> Error (@errorRows)</span>
                <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-gray-300"></span> Pending (@pendingRows)</span>
            </div>
        </div>
    }

    <!-- Batches Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background: #EBF4F6; color: #088395;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">Batch Validation Summary</h3>
                <p class="text-xs text-gray-400">Cleansing results per data batch</p>
            </div>
        </div>

        @if (allBatches != null && allBatches.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr style="border-bottom: 2px solid #EBF4F6;">
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Batch ID</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Source</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Target</th>
                            <th class="text-center py-3 px-4 font-semibold" style="color: #088395;">Total</th>
                            <th class="text-center py-3 px-4 font-semibold text-green-600">Valid</th>
                            <th class="text-center py-3 px-4 font-semibold text-yellow-600">Warn</th>
                            <th class="text-center py-3 px-4 font-semibold text-red-500">Error</th>
                            <th class="text-center py-3 px-4 font-semibold text-gray-400">Pending</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Pulled At</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in allBatches)
                        {
                            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                                <td class="py-3 px-4 font-mono text-xs font-semibold text-gray-800">@b.BatchId</td>
                                <td class="py-3 px-4 text-gray-600">@b.DataSourceName</td>
                                <td class="py-3 px-4 font-mono text-xs text-gray-500">@b.TargetTable</td>
                                <td class="py-3 px-4 text-center font-semibold text-gray-800">@b.TotalRows</td>
                                <td class="py-3 px-4 text-center text-green-600 font-semibold">@b.ValidRows</td>
                                <td class="py-3 px-4 text-center text-yellow-600 font-semibold">@b.WarningRows</td>
                                <td class="py-3 px-4 text-center text-red-500 font-semibold">@b.ErrorRows</td>
                                <td class="py-3 px-4 text-center text-gray-400">@b.PendingRows</td>
                                <td class="py-3 px-4 text-gray-500">@(((DateTime)b.PulledAt).ToString("MMM dd, yyyy hh:mm tt"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-12 text-gray-400">
                <svg class="w-12 h-12 mx-auto mb-4" style="color: #7AB2B2;" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-sm font-medium">No validation data yet</p>
                <p class="text-xs mt-1">Validation results appear here after Staff pulls and verifies data</p>
            </div>
        }
    </div>
</div>
