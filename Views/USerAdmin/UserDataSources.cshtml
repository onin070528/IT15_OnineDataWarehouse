@using it15_webproject_mvc.Models
@{
    var sources = ViewData["AllSources"] as List<DataSource> ?? new List<DataSource>();
    var totalSources = (int)(ViewData["TotalSources"] ?? 0);
    var activeSources = (int)(ViewData["ActiveSources"] ?? 0);
}

<div class="p-8 bg-gray-100 min-h-full">

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-8">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <p class="text-2xl font-bold" style="color: #09637E;">@totalSources</p>
            <p class="text-xs text-gray-400 mt-1">Total Data Sources</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <p class="text-2xl font-bold" style="color: #088395;">@activeSources</p>
            <p class="text-xs text-gray-400 mt-1">Active Sources</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <p class="text-2xl font-bold" style="color: #7AB2B2;">@(totalSources - activeSources)</p>
            <p class="text-xs text-gray-400 mt-1">Inactive Sources</p>
        </div>
    </div>

    <!-- Admin control notice -->
    <div class="rounded-lg px-4 py-3 mb-6" style="background-color: #EBF4F6; border: 1px solid #7AB2B2;">
        <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" style="color: #088395;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-xs" style="color: #09637E;"><strong>Admin controls.</strong> You can activate or deactivate data sources. Staff members manage source creation and connections.</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-200 flex items-center gap-3">
            <span class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
            </span>
            <p class="text-sm font-medium text-emerald-800">@TempData["Success"]</p>
        </div>
    }

    <!-- Sources Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background: #EBF4F6; color: #088395;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">Configured API Sources</h3>
                <p class="text-xs text-gray-400">External data source connections for your organization</p>
            </div>
        </div>

        @if (sources.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr style="border-bottom: 2px solid #EBF4F6;">
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Source Name</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">API Endpoint</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Target Table</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Auth Method</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Created By</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Last Sync</th>
                            <th class="text-center py-3 px-4 font-semibold" style="color: #088395;">Status</th>
                            <th class="text-center py-3 px-4 font-semibold" style="color: #088395;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in sources)
                        {
                            var statusBg = s.Status == "Active" ? "text-green-600 bg-green-50" : "text-gray-500 bg-gray-100";
                            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                                <td class="py-3 px-4 font-semibold text-gray-800">@s.SourceName</td>
                                <td class="py-3 px-4 font-mono text-xs text-gray-500">@s.ApiBaseUrl@s.ApiEndpoint</td>
                                <td class="py-3 px-4 font-mono text-xs text-gray-600">@s.TargetTable</td>
                                <td class="py-3 px-4 text-gray-500">@s.AuthMethod</td>
                                <td class="py-3 px-4 text-gray-600">@(s.CreatedByUser?.Full_name ?? "—")</td>
                                <td class="py-3 px-4 text-gray-500">@(s.Last_sync?.ToString("MMM dd, yyyy hh:mm tt") ?? "Never")</td>
                                <td class="py-3 px-4 text-center">
                                    <span class="text-xs font-medium px-2.5 py-1 rounded-full @statusBg">@s.Status</span>
                                </td>
                                <td class="py-3 px-4 text-center">
                                    <form method="post" asp-action="ToggleSourceStatus" asp-controller="UserAdmin" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="dataSourceId" value="@s.DataSourceID" />
                                        <button type="submit" class="px-3 py-1 text-xs font-semibold rounded-lg transition-colors @(s.Status == "Active" ? "text-red-600 bg-red-50 hover:bg-red-100" : "text-green-600 bg-green-50 hover:bg-green-100")">
                                            @(s.Status == "Active" ? "Deactivate" : "Activate")
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-12 text-gray-400">
                <svg class="w-12 h-12 mx-auto mb-4" style="color: #7AB2B2;" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                </svg>
                <p class="text-sm font-medium">No data sources configured yet</p>
                <p class="text-xs mt-1">Staff members can add API sources from their portal</p>
            </div>
        }
    </div>
</div>
