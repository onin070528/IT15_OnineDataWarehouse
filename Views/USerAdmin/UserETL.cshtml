@using it15_webproject_mvc.Models
@{
    var submissions = ViewData["AllSubmissions"] as List<DataSubmission> ?? new List<DataSubmission>();
    var totalSubmissions = (int)(ViewData["TotalSubmissions"] ?? 0);
    var integratedCount = (int)(ViewData["IntegratedCount"] ?? 0);
    var pendingCount = (int)(ViewData["PendingCount"] ?? 0);
    var failedCount = (int)(ViewData["FailedCount"] ?? 0);
    var totalRowsProcessed = (int)(ViewData["TotalRowsProcessed"] ?? 0);
}

<div class="p-8 bg-gray-100 min-h-full">

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-5 mb-8">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <p class="text-2xl font-bold" style="color: #09637E;">@totalSubmissions</p>
            <p class="text-xs text-gray-400 mt-1">Total Submissions</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <p class="text-2xl font-bold" style="color: #088395;">@integratedCount</p>
            <p class="text-xs text-gray-400 mt-1">Integrated</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <p class="text-2xl font-bold" style="color: #7AB2B2;">@pendingCount</p>
            <p class="text-xs text-gray-400 mt-1">Pending Approval</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <p class="text-2xl font-bold text-red-500">@failedCount</p>
            <p class="text-xs text-gray-400 mt-1">Failed / Rejected</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <p class="text-2xl font-bold" style="color: #09637E;">@totalRowsProcessed.ToString("N0")</p>
            <p class="text-xs text-gray-400 mt-1">Rows Processed</p>
        </div>
    </div>

    <!-- Read-only notice -->
    <div class="rounded-lg px-4 py-3 mb-6" style="background-color: #EBF4F6; border: 1px solid #7AB2B2;">
        <div class="flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" style="color: #088395;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-xs" style="color: #09637E;"><strong>Read-only view.</strong> ETL submissions are created by Staff and approved by Managers.</p>
        </div>
    </div>

    <!-- Submissions Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background: #EBF4F6; color: #088395;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">ETL Submissions</h3>
                <p class="text-xs text-gray-400">Data integration pipeline submissions for your organization</p>
            </div>
        </div>

        @if (submissions.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr style="border-bottom: 2px solid #EBF4F6;">
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Batch ID</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Source</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Target</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Rows</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Mode</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Submitted By</th>
                            <th class="text-left py-3 px-4 font-semibold" style="color: #088395;">Date</th>
                            <th class="text-center py-3 px-4 font-semibold" style="color: #088395;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sub in submissions)
                        {
                            var statusBg = sub.Status == "Integrated" ? "text-green-600 bg-green-50" :
                                           sub.Status == "Submitted" ? "text-blue-600 bg-blue-50" :
                                           sub.Status == "Failed" ? "text-red-600 bg-red-50" : "text-gray-500 bg-gray-100";
                            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                                <td class="py-3 px-4 font-mono text-xs font-semibold text-gray-800">@sub.BatchId</td>
                                <td class="py-3 px-4 text-gray-600">@(sub.DataSource?.SourceName ?? "Ś")</td>
                                <td class="py-3 px-4 font-mono text-xs text-gray-500">@sub.TargetTable</td>
                                <td class="py-3 px-4 text-gray-600">@sub.ValidRows / @sub.TotalRows</td>
                                <td class="py-3 px-4 text-gray-500">@sub.LoadMode</td>
                                <td class="py-3 px-4 text-gray-600">@(sub.SubmittedByUser?.Full_name ?? "Ś")</td>
                                <td class="py-3 px-4 text-gray-500">@sub.Created_at.ToString("MMM dd, yyyy hh:mm tt")</td>
                                <td class="py-3 px-4 text-center">
                                    <span class="text-xs font-medium px-2.5 py-1 rounded-full @statusBg">@sub.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-12 text-gray-400">
                <svg class="w-12 h-12 mx-auto mb-4" style="color: #7AB2B2;" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                </svg>
                <p class="text-sm font-medium">No ETL submissions yet</p>
                <p class="text-xs mt-1">Staff members submit data batches through their portal</p>
            </div>
        }
    </div>
</div>
