@{
    var totalSources = (int)(ViewData["TotalSources"] ?? 0);
    var totalBatches = (int)(ViewData["TotalBatches"] ?? 0);
    var totalSubmissions = (int)(ViewData["TotalSubmissions"] ?? 0);
    var totalStagingRows = (int)(ViewData["TotalStagingRows"] ?? 0);
    var formattedStagingRows = totalStagingRows.ToString("N0");

    var sourceSummary = ViewData["SourceSummary"] as dynamic;
    var statusBreakdown = ViewData["StatusBreakdown"] as dynamic;
    var monthlySubmissions = ViewData["MonthlySubmissions"] as dynamic;
    var monthlyRecordsPulled = ViewData["MonthlyRecordsPulled"] as dynamic;
    var validationSummary = ViewData["ValidationSummary"] as dynamic;

    // Pre-build all JSON arrays for charts
    var statusLabelsJson = "[]";
    var statusCountsJson = "[]";
    var statusRowsJson = "[]";
    if (statusBreakdown != null)
    {
        var sbList = ((IEnumerable<dynamic>)statusBreakdown).ToList();
        statusLabelsJson = "[" + string.Join(",", sbList.Select(s => "\"" + (string)s.Status + "\"")) + "]";
        statusCountsJson = "[" + string.Join(",", sbList.Select(s => ((int)s.Count).ToString())) + "]";
        statusRowsJson = "[" + string.Join(",", sbList.Select(s => ((int)s.Rows).ToString())) + "]";
    }

    var monthlyLabelsJson = "[]";
    var monthlyCountsJson = "[]";
    var monthlyRowsJson = "[]";
    if (monthlySubmissions != null)
    {
        var msList = ((IEnumerable<dynamic>)monthlySubmissions).Reverse().ToList();
        monthlyLabelsJson = "[" + string.Join(",", msList.Select(m => "\"" + new DateTime((int)m.Year, (int)m.Month, 1).ToString("MMM yyyy") + "\"")) + "]";
        monthlyCountsJson = "[" + string.Join(",", msList.Select(m => ((int)m.Count).ToString())) + "]";
        monthlyRowsJson = "[" + string.Join(",", msList.Select(m => ((int)m.Rows).ToString())) + "]";
    }

    var pulledLabelsJson = "[]";
    var pulledCountsJson = "[]";
    if (monthlyRecordsPulled != null)
    {
        var prList = ((IEnumerable<dynamic>)monthlyRecordsPulled).ToList();
        pulledLabelsJson = "[" + string.Join(",", prList.Select(m => "\"" + new DateTime((int)m.Year, (int)m.Month, 1).ToString("MMM yyyy") + "\"")) + "]";
        pulledCountsJson = "[" + string.Join(",", prList.Select(m => ((int)m.Count).ToString())) + "]";
    }

    var validLabelsJson = "[]";
    var validCountsJson = "[]";
    if (validationSummary != null)
    {
        var vsList = ((IEnumerable<dynamic>)validationSummary).ToList();
        validLabelsJson = "[" + string.Join(",", vsList.Select(v => "\"" + (string)v.Status + "\"")) + "]";
        validCountsJson = "[" + string.Join(",", vsList.Select(v => ((int)v.Count).ToString())) + "]";
    }

    // Pre-build PDF table HTML (use double quotes escaped for JS)
    var pdfStatusHtml = "";
    if (statusBreakdown != null)
    {
        foreach (var sb in (IEnumerable<dynamic>)statusBreakdown)
        {
            pdfStatusHtml += "<tr><td>" + (string)sb.Status + "</td><td style=\\\"text-align:center\\\">" + ((int)sb.Count) + "</td><td style=\\\"text-align:center\\\">" + ((int)sb.Rows) + "</td></tr>";
        }
    }

    var pdfMonthlyHtml = "";
    if (monthlySubmissions != null)
    {
        foreach (var m in (IEnumerable<dynamic>)monthlySubmissions)
        {
            var ml = new DateTime((int)m.Year, (int)m.Month, 1).ToString("MMM yyyy");
            pdfMonthlyHtml += "<tr><td>" + ml + "</td><td style=\\\"text-align:center\\\">" + ((int)m.Count) + "</td><td style=\\\"text-align:center\\\">" + ((int)m.Rows) + "</td></tr>";
        }
    }

    var pdfValidHtml = "";
    if (validationSummary != null)
    {
        foreach (var v in (IEnumerable<dynamic>)validationSummary)
        {
            pdfValidHtml += "<tr><td>" + (string)v.Status + "</td><td style=\\\"text-align:center\\\">" + ((int)v.Count) + "</td></tr>";
        }
    }
}

<div class="p-8 bg-gray-100 min-h-full" id="staff-report-root">

    <!-- Header with Export Button -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h2 class="text-xl font-bold text-gray-900">Staff Activity Reports</h2>
            <p class="text-sm text-gray-500 mt-1">Visual overview of your data warehouse activity</p>
        </div>
        <button onclick="exportReportPDF()"
                class="flex items-center gap-2 px-5 py-2.5 text-white rounded-lg text-sm font-semibold transition-colors"
                style="background-color: #088395;"
                onmouseover="this.style.backgroundColor='#09637E'"
                onmouseout="this.style.backgroundColor='#088395'">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            Export PDF
        </button>
    </div>

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-900">@totalSources</p>
                    <p class="text-xs text-gray-400">Data Sources</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #09637E;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-900">@totalBatches</p>
                    <p class="text-xs text-gray-400">Batches Pulled</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #7AB2B2;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-900">@totalSubmissions</p>
                    <p class="text-xs text-gray-400">Submissions</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-900">@formattedStagingRows</p>
                    <p class="text-xs text-gray-400">Total Staging Rows</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row 1 -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/>
                        <path d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold" style="color: #09637E;">Submission Status</h3>
                    <p class="text-xs text-gray-400">Breakdown by current status</p>
                </div>
            </div>
            <div class="flex items-center justify-center" style="height: 280px;">
                <canvas id="statusDoughnutChart"></canvas>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #09637E;">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold" style="color: #09637E;">Monthly Submissions</h3>
                    <p class="text-xs text-gray-400">Submissions per month (last 12 months)</p>
                </div>
            </div>
            <div style="height: 280px;">
                <canvas id="monthlyBarChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Charts Row 2 -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #7AB2B2;">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold" style="color: #09637E;">Records Pulled Over Time</h3>
                    <p class="text-xs text-gray-400">Staging records pulled per month</p>
                </div>
            </div>
            <div style="height: 280px;">
                <canvas id="recordsLineChart"></canvas>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold" style="color: #09637E;">Data Validation Summary</h3>
                    <p class="text-xs text-gray-400">Breakdown of staging record validation results</p>
                </div>
            </div>
            <div class="flex items-center justify-center" style="height: 280px;">
                <canvas id="validationPieChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Source Summary Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold" style="color: #09637E;">Source Summary Report</h3>
                <p class="text-xs text-gray-400">Data volume per configured source</p>
            </div>
        </div>
        @if (sourceSummary != null && ((System.Collections.ICollection)sourceSummary!).Count > 0)
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm" id="source-summary-table">
                    <thead>
                        <tr class="border-b border-gray-200">
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Source</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Target Table</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Batches</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Total Rows</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Last Sync</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in (IEnumerable<dynamic>)sourceSummary!)
                        {
                            var statusColor = (string)s.Status == "Active" ? "text-green-600 bg-green-50" :
                                              (string)s.Status == "Error" ? "text-red-600 bg-red-50" : "text-gray-500 bg-gray-100";
                            var formattedRows = ((int)s.TotalRows).ToString("N0");
                            <tr class="border-b border-gray-100 hover:bg-gray-50">
                                <td class="py-3 px-4 font-semibold text-gray-800">@s.SourceName</td>
                                <td class="py-3 px-4 font-mono text-xs text-gray-500">@s.TargetTable</td>
                                <td class="py-3 px-4 text-center text-gray-600">@s.BatchCount</td>
                                <td class="py-3 px-4 text-center font-semibold text-gray-800">@formattedRows</td>
                                <td class="py-3 px-4 text-gray-500 text-xs">@(s.Last_sync != null ? ((DateTime)s.Last_sync).ToString("MMM dd, yyyy") : "Never")</td>
                                <td class="py-3 px-4 text-center"><span class="text-xs font-medium px-2.5 py-1 rounded-full @statusColor">@s.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-sm text-gray-400 text-center py-6">No sources configured yet.</p>
        }
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
(function waitForChart() {
    if (typeof Chart === 'undefined') { setTimeout(waitForChart, 150); return; }

    var statusLabels = @Html.Raw(statusLabelsJson);
    var statusCounts = @Html.Raw(statusCountsJson);
    var statusRows = @Html.Raw(statusRowsJson);
    var monthlyLabels = @Html.Raw(monthlyLabelsJson);
    var monthlyCounts = @Html.Raw(monthlyCountsJson);
    var monthlyRows = @Html.Raw(monthlyRowsJson);
    var pulledLabels = @Html.Raw(pulledLabelsJson);
    var pulledCounts = @Html.Raw(pulledCountsJson);
    var validLabels = @Html.Raw(validLabelsJson);
    var validCounts = @Html.Raw(validCountsJson);

    var sMap = {'Integrated':'#088395','Submitted':'#f59e0b','Failed':'#ef4444','Verified':'#3b82f6','Pending':'#9ca3af'};
    var vMap = {'Valid':'#10b981','Warning':'#f59e0b','Error':'#ef4444','Pending':'#9ca3af'};
    var anim = {duration:1200, easing:'easeOutQuart'};

    if (statusLabels.length > 0) {
        new Chart(document.getElementById('statusDoughnutChart'), {
            type:'doughnut',
            data:{labels:statusLabels, datasets:[{data:statusCounts, backgroundColor:statusLabels.map(function(l){return sMap[l]||'#d1d5db';}), borderWidth:2, borderColor:'#fff', hoverOffset:8}]},
            options:{responsive:true, maintainAspectRatio:false, animation:anim, cutout:'60%',
                plugins:{legend:{position:'bottom',labels:{padding:16,usePointStyle:true,pointStyle:'circle',font:{size:12}}},
                    tooltip:{callbacks:{afterLabel:function(c){return statusRows[c.dataIndex]+' rows';}}}}}
        });
    }

    if (monthlyLabels.length > 0) {
        new Chart(document.getElementById('monthlyBarChart'), {
            type:'bar',
            data:{labels:monthlyLabels, datasets:[
                {label:'Submissions',data:monthlyCounts,backgroundColor:'#088395',borderRadius:6,barPercentage:0.6},
                {label:'Total Rows',data:monthlyRows,backgroundColor:'#7AB2B2',borderRadius:6,barPercentage:0.6}]},
            options:{responsive:true, maintainAspectRatio:false, animation:anim,
                plugins:{legend:{position:'bottom',labels:{padding:16,usePointStyle:true,pointStyle:'rect',font:{size:12}}}},
                scales:{y:{beginAtZero:true,grid:{color:'#f3f4f6'},ticks:{font:{size:11}}},x:{grid:{display:false},ticks:{font:{size:11}}}}}
        });
    }

    if (pulledLabels.length > 0) {
        new Chart(document.getElementById('recordsLineChart'), {
            type:'line',
            data:{labels:pulledLabels, datasets:[{label:'Records Pulled',data:pulledCounts,borderColor:'#088395',backgroundColor:'rgba(8,131,149,0.1)',tension:0.4,fill:true,pointBackgroundColor:'#088395',pointBorderColor:'#fff',pointBorderWidth:2,pointRadius:5,pointHoverRadius:7}]},
            options:{responsive:true, maintainAspectRatio:false, animation:anim,
                plugins:{legend:{position:'bottom',labels:{padding:16,usePointStyle:true,pointStyle:'circle',font:{size:12}}}},
                scales:{y:{beginAtZero:true,grid:{color:'#f3f4f6'},ticks:{font:{size:11}}},x:{grid:{display:false},ticks:{font:{size:11}}}}}
        });
    }

    if (validLabels.length > 0) {
        new Chart(document.getElementById('validationPieChart'), {
            type:'pie',
            data:{labels:validLabels, datasets:[{data:validCounts, backgroundColor:validLabels.map(function(l){return vMap[l]||'#d1d5db';}), borderWidth:2, borderColor:'#fff', hoverOffset:8}]},
            options:{responsive:true, maintainAspectRatio:false, animation:anim,
                plugins:{legend:{position:'bottom',labels:{padding:16,usePointStyle:true,pointStyle:'circle',font:{size:12}}}}}
        });
    }
})();

function exportReportPDF() {
    var statusHtml = "@Html.Raw(pdfStatusHtml)";
    var monthlyHtml = "@Html.Raw(pdfMonthlyHtml)";
    var validHtml = "@Html.Raw(pdfValidHtml)";

    var sourceHtml = '';
    var tbl = document.getElementById('source-summary-table');
    if (tbl) {
        tbl.querySelectorAll('tbody tr').forEach(function(row) {
            sourceHtml += '<tr>';
            row.querySelectorAll('td').forEach(function(cell) { sourceHtml += '<td>' + cell.textContent.trim() + '</td>'; });
            sourceHtml += '</tr>';
        });
    }

    var h = '<!DOCTYPE html><html><head><title>Staff Report</title><style>' +
        'body{font-family:Arial,sans-serif;font-size:12px;margin:30px;color:#333}' +
        'h1{color:#09637E;font-size:22px;margin-bottom:4px}' +
        'h2{color:#088395;font-size:15px;margin-top:28px;margin-bottom:8px;border-bottom:2px solid #EBF4F6;padding-bottom:4px}' +
        '.meta{color:#888;font-size:10px;margin-bottom:20px}' +
        '.kg{display:flex;gap:16px;margin-bottom:24px}' +
        '.kc{flex:1;background:#EBF4F6;border-radius:8px;padding:14px;text-align:center}' +
        '.kv{font-size:22px;font-weight:bold;color:#09637E}' +
        '.kl{font-size:10px;color:#666;margin-top:2px}' +
        'table{width:100%;border-collapse:collapse;margin-top:8px}' +
        'th{background:#088395;color:white;padding:8px;text-align:left;font-size:11px}' +
        'td{padding:6px 8px;border-bottom:1px solid #e5e7eb;font-size:11px}' +
        'tr:nth-child(even){background:#f9fafb}' +
        '</style></head><body>' +
        '<h1>Staff Activity Report</h1>' +
        '<p class="meta">Generated on ' + new Date().toLocaleString() + '</p>' +
        '<div class="kg">' +
        '<div class="kc"><div class="kv">@totalSources</div><div class="kl">Data Sources</div></div>' +
        '<div class="kc"><div class="kv">@totalBatches</div><div class="kl">Batches Pulled</div></div>' +
        '<div class="kc"><div class="kv">@totalSubmissions</div><div class="kl">Submissions</div></div>' +
        '<div class="kc"><div class="kv">@formattedStagingRows</div><div class="kl">Staging Rows</div></div>' +
        '</div>';

    if (statusHtml) {
        h += '<h2>Submission Status Breakdown</h2><table><thead><tr><th>Status</th><th style="text-align:center">Count</th><th style="text-align:center">Total Rows</th></tr></thead><tbody>' + statusHtml + '</tbody></table>';
    }
    if (validHtml) {
        h += '<h2>Data Validation Summary</h2><table><thead><tr><th>Validation Status</th><th style="text-align:center">Records</th></tr></thead><tbody>' + validHtml + '</tbody></table>';
    }
    if (monthlyHtml) {
        h += '<h2>Monthly Submission Trend</h2><table><thead><tr><th>Month</th><th style="text-align:center">Submissions</th><th style="text-align:center">Total Rows</th></tr></thead><tbody>' + monthlyHtml + '</tbody></table>';
    }
    if (sourceHtml) {
        h += '<h2>Source Summary</h2><table><thead><tr><th>Source</th><th>Target Table</th><th style="text-align:center">Batches</th><th style="text-align:center">Total Rows</th><th>Last Sync</th><th style="text-align:center">Status</th></tr></thead><tbody>' + sourceHtml + '</tbody></table>';
    }

    h += '</body></html>';
    var w = window.open('', '_blank');
    w.document.write(h);
    w.document.close();
    setTimeout(function(){ w.print(); }, 300);
}
</script>
