@using it15_webproject_mvc.Models
@using System.Text.Json
@{
    var dataSources = ViewData["DataSources"] as List<DataSource> ?? new List<DataSource>();
    var recentBatches = ViewData["RecentBatches"] as dynamic;
    var pendingBatches = ViewData["PendingBatches"] as Dictionary<int, dynamic> ?? new Dictionary<int, dynamic>();
    var pullError = TempData["PullError"] as string;
    var pullSuccess = TempData["PullSuccess"] as string;
}

<!-- UPLOAD / PULL DATA -->
<div class="p-8 bg-gray-100 min-h-full">

    <!-- Step Indicator -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 mb-8">
        <div class="flex items-center justify-between max-w-2xl mx-auto">
            <div class="flex items-center gap-3">
                <span class="w-10 h-10 rounded-full text-white flex items-center justify-center text-sm font-bold" style="background-color: #088395;">1</span>
                <div>
                    <p class="text-sm font-bold text-gray-900">Pull / Upload</p>
                    <p class="text-xs text-gray-400">Current Step</p>
                </div>
            </div>
            <div class="flex-1 h-0.5 bg-gray-200 mx-4"></div>
            <div class="flex items-center gap-3">
                <span class="w-10 h-10 rounded-full bg-gray-200 text-gray-400 flex items-center justify-center text-sm font-bold">2</span>
                <div>
                    <p class="text-sm font-medium text-gray-400">Verify</p>
                    <p class="text-xs text-gray-300">Next</p>
                </div>
            </div>
            <div class="flex-1 h-0.5 bg-gray-200 mx-4"></div>
            <div class="flex items-center gap-3">
                <span class="w-10 h-10 rounded-full bg-gray-200 text-gray-400 flex items-center justify-center text-sm font-bold">3</span>
                <div>
                    <p class="text-sm font-medium text-gray-400">Submit</p>
                    <p class="text-xs text-gray-300">Final</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Alerts -->
    @if (pullError != null)
    {
        <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-200 flex items-center gap-3">
            <span class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg>
            </span>
            <p class="text-sm font-medium text-red-800">@pullError</p>
        </div>
    }
    @if (pullSuccess != null)
    {
        <div class="mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-200 flex items-center gap-3">
            <span class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
            </span>
            <p class="text-sm font-medium text-emerald-800">@pullSuccess</p>
        </div>
    }

    <!-- Pull from API -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 mb-8">
        <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: #EBF4F6; color: #088395;">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-bold text-gray-900">Pull Data from API</h3>
                <p class="text-sm text-gray-500">Select a configured API source and pull data into staging</p>
            </div>
        </div>

        @if (dataSources.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                @foreach (var source in dataSources)
                {
                    var hasPending = pendingBatches.ContainsKey(source.DataSourceID);
                    var pendingBatchId = hasPending ? (string)pendingBatches[source.DataSourceID].BatchId : null;
                    var pendingRowCount = hasPending ? (int)pendingBatches[source.DataSourceID].RowCount : 0;

                    <div class="border rounded-xl p-5 hover:shadow-sm transition-all @(hasPending ? "border-amber-300 bg-amber-50/30" : "border-gray-200")" onmouseover="this.style.borderColor='@(hasPending ? "#f59e0b" : "#7AB2B2")'" onmouseout="this.style.borderColor='@(hasPending ? "#fcd34d" : "")'">
                        <div class="flex items-center gap-2 mb-3">
                            <span class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: @(hasPending ? "#fef3c7" : "#EBF4F6"); color: @(hasPending ? "#d97706" : "#088395");">
                                @if (hasPending)
                                {
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path d="M5 12h14M12 5l7 7-7 7"/>
                                    </svg>
                                }
                            </span>
                            <h4 class="text-sm font-bold text-gray-900">@source.SourceName</h4>
                        </div>
                        <div class="space-y-1.5 text-xs text-gray-500 mb-4">
                            <div class="flex justify-between"><span>Endpoint</span><span class="font-mono text-gray-600 truncate max-w-[140px]">@source.ApiEndpoint</span></div>
                            <div class="flex justify-between"><span>Target</span><span class="font-mono text-gray-600">@source.TargetTable</span></div>
                            <div class="flex justify-between"><span>Last Sync</span><span>@(source.Last_sync?.ToString("MMM dd, hh:mm tt") ?? "Never")</span></div>
                        </div>

                        @if (hasPending)
                        {
                            <div class="mb-3 p-2.5 rounded-lg bg-amber-50 border border-amber-200">
                                <p class="text-xs font-medium text-amber-800 mb-1">? Unsubmitted batch exists</p>
                                <p class="text-xs text-amber-600">@pendingRowCount row(s) pending in batch</p>
                            </div>
                            <div class="flex gap-2">
                                <a href="@Url.Action("StaffNav", "Staff", new { section = "verify" })"
                                   class="flex-1 px-3 py-2.5 text-center text-white rounded-lg text-xs font-semibold no-underline transition-colors" style="background-color: #088395;">
                                    Verify & Submit
                                </a>
                                <form method="post" asp-action="DiscardBatch" asp-controller="Staff" class="flex-1"
                                      onsubmit="return confirm('Discard @pendingRowCount staging record(s) from this source? This cannot be undone.');">
                                    <input type="hidden" name="dataSourceId" value="@source.DataSourceID" />
                                    <button type="submit"
                                            class="w-full px-3 py-2.5 text-red-700 bg-red-50 border border-red-200 rounded-lg text-xs font-semibold transition-colors hover:bg-red-100">
                                        Discard
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <form method="post" asp-action="PullFromApi" asp-controller="Staff">
                                <input type="hidden" name="dataSourceId" value="@source.DataSourceID" />
                                <button type="submit"
                                        class="w-full px-4 py-2.5 text-white rounded-lg text-sm font-semibold transition-colors" style="background-color: #088395;" onmouseover="this.style.backgroundColor='#09637E'" onmouseout="this.style.backgroundColor='#088395'">
                                    Pull Data Now
                                </button>
                            </form>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-8">
                <p class="text-sm text-gray-400 mb-3">No API sources configured yet.</p>
                <a href="@Url.Action("StaffNav", "Staff", new { section = "sources" })"
                   class="px-4 py-2 text-white rounded-lg text-sm font-semibold no-underline" style="background-color: #088395;" onmouseover="this.style.backgroundColor='#09637E'" onmouseout="this.style.backgroundColor='#088395'">
                    Configure API Sources
                </a>
            </div>
        }
    </div>

    <!-- Recent Batches -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
        <h3 class="text-lg font-bold text-gray-900 mb-5">Recent Data Pulls</h3>
        @if (recentBatches != null)
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200">
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Batch ID</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Source</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Target</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Rows</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Pulled At</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var batch in recentBatches)
                        {
                            var statusColor = (string)batch.Status == "Submitted" ? "text-purple-600 bg-purple-50" :
                                              (string)batch.Status == "Verified" ? "text-blue-600 bg-blue-50" :
                                              (string)batch.Status == "Pending" ? "text-yellow-600 bg-yellow-50" : "text-red-600 bg-red-50";
                            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                                <td class="py-3 px-4 font-mono text-xs font-semibold text-gray-800">@batch.BatchId</td>
                                <td class="py-3 px-4 text-gray-600">@batch.DataSourceName</td>
                                <td class="py-3 px-4 font-mono text-gray-500">@batch.TargetTable</td>
                                <td class="py-3 px-4 text-gray-600">@batch.RowCount</td>
                                <td class="py-3 px-4 text-gray-500">@(((DateTime)batch.PulledAt).ToString("MMM dd, yyyy hh:mm tt"))</td>
                                <td class="py-3 px-4 text-center">
                                    <span class="text-xs font-medium px-2.5 py-1 rounded-full @statusColor">@batch.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-sm text-gray-400 text-center py-6">No data pulled yet. Select an API source above and click "Pull Data Now".</p>
        }
    </div>
</div>
