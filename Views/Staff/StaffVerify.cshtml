@using it15_webproject_mvc.Models
@using System.Text.Json
@{
    var batches = ViewData["VerifyBatches"] as dynamic;
    var previewRecords = ViewData["PreviewRecords"] as List<StagingRecord>;
    var previewBatchId = ViewData["PreviewBatchId"] as string;
    var previewBatchInfo = ViewData["PreviewBatchInfo"] as dynamic;
    var previewPage = (int)(ViewData["PreviewPage"] ?? 1);
    var previewPageSize = (int)(ViewData["PreviewPageSize"] ?? 20);
    var previewTotalRows = (int)(ViewData["PreviewTotalRows"] ?? 0);
    var totalPages = previewPageSize > 0 ? (int)Math.Ceiling(previewTotalRows / (double)previewPageSize) : 1;
    var validateSuccess = TempData["ValidateSuccess"] as string;
    var correctError = TempData["CorrectError"] as string;
}

<!-- VERIFY DATA -->
<div class="p-8 bg-gray-100 min-h-full">

    <!-- Step Indicator -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 mb-8">
        <div class="flex items-center justify-between max-w-2xl mx-auto">
            <div class="flex items-center gap-3">
                <span class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold" style="background-color: #EBF4F6; color: #088395;">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
                </span>
                <div>
                    <p class="text-sm font-medium" style="color: #088395;">Pull / Upload</p>
                    <p class="text-xs text-gray-400">Completed</p>
                </div>
            </div>
            <div class="flex-1 h-0.5 mx-4" style="background-color: #7AB2B2;"></div>
            <div class="flex items-center gap-3">
                <span class="w-10 h-10 rounded-full text-white flex items-center justify-center text-sm font-bold" style="background-color: #088395;">2</span>
                <div>
                    <p class="text-sm font-bold text-gray-900">Verify</p>
                    <p class="text-xs text-gray-400">Current Step</p>
                </div>
            </div>
            <div class="flex-1 h-0.5 bg-gray-200 mx-4"></div>
            <div class="flex items-center gap-3">
                <span class="w-10 h-10 rounded-full bg-gray-200 text-gray-400 flex items-center justify-center text-sm font-bold">3</span>
                <div>
                    <p class="text-sm font-medium text-gray-400">Submit</p>
                    <p class="text-xs text-gray-300">Final</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Validate Alert -->
    @if (validateSuccess != null)
    {
        <div class="mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-200 flex items-center gap-3">
            <span class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
            </span>
            <p class="text-sm font-medium text-emerald-800">@validateSuccess</p>
        </div>
    }
    @if (correctError != null)
    {
        <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-200 flex items-center gap-3">
            <span class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg>
            </span>
            <p class="text-sm font-medium text-red-800">@correctError</p>
        </div>
    }

    <!-- Batches Awaiting Verification -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 mb-8">
        <h3 class="text-lg font-bold text-gray-900 mb-5">Batches Awaiting Verification</h3>

        @if (batches != null && ((IEnumerable<dynamic>)batches!).Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200">
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Batch ID</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Source</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Total</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Valid</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Errors</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Pending</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var batch in batches!)
                        {
                            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                                <td class="py-3 px-4 font-mono text-xs font-semibold text-gray-800">@batch.BatchId</td>
                                <td class="py-3 px-4 text-gray-600">@batch.DataSourceName</td>
                                <td class="py-3 px-4 text-gray-600">@batch.TotalRows</td>
                                <td class="py-3 px-4 text-emerald-600 font-semibold">@batch.ValidRows</td>
                                <td class="py-3 px-4 text-red-500 font-semibold">@batch.ErrorRows</td>
                                <td class="py-3 px-4 text-yellow-600 font-semibold">@batch.PendingRows</td>
                                <td class="py-3 px-4 text-center">
                                    <form method="post" asp-action="ValidateBatch" asp-controller="Staff" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="batchId" value="@batch.BatchId" />
                                        <button type="submit"
                                                class="px-4 py-1.5 text-white rounded-lg text-xs font-semibold transition-colors" style="background-color: #088395;" onmouseover="this.style.backgroundColor='#09637E'" onmouseout="this.style.backgroundColor='#088395'">
                                            Validate
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-sm text-gray-400 text-center py-6">No batches awaiting verification. Pull data from an API source first.</p>
        }
    </div>

    <!-- Data Preview -->
    @if (previewRecords != null && previewRecords.Any())
    {
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 mb-8">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h3 class="text-lg font-bold text-gray-900">Data Preview &mdash; @previewBatchId</h3>
                    <p class="text-sm text-gray-500 mt-1">
                        Showing rows @((previewPage - 1) * previewPageSize + 1)-@Math.Min(previewPage * previewPageSize, previewTotalRows) of @previewTotalRows
                    </p>
                </div>
            </div>

            <!-- Validation Summary Cards -->
            @if (previewBatchInfo != null)
            {
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
                    <div class="bg-gray-50 rounded-xl p-4 text-center">
                        <p class="text-2xl font-bold text-gray-900">@previewBatchInfo.TotalRows</p>
                        <p class="text-xs text-gray-400">Total Rows</p>
                    </div>
                    <div class="bg-emerald-50 rounded-xl p-4 text-center">
                        <p class="text-2xl font-bold text-emerald-600">@previewBatchInfo.ValidRows</p>
                        <p class="text-xs text-gray-400">Valid</p>
                    </div>
                    <div class="bg-yellow-50 rounded-xl p-4 text-center">
                        <p class="text-2xl font-bold text-yellow-600">@previewBatchInfo.WarningRows</p>
                        <p class="text-xs text-gray-400">Warnings</p>
                    </div>
                    <div class="bg-red-50 rounded-xl p-4 text-center">
                        <p class="text-2xl font-bold text-red-600">@previewBatchInfo.ErrorRows</p>
                        <p class="text-xs text-gray-400">Errors</p>
                    </div>
                </div>
            }

            <style>
                .row-data-collapsed {
                    max-height: 2rem;
                    overflow: hidden;
                    transition: max-height 0.3s ease;
                }
                .row-data-expanded {
                    max-height: none;
                    transition: max-height 0.3s ease;
                }
                .expand-icon {
                    transition: transform 0.3s ease;
                }
                .expand-icon.rotated {
                    transform: rotate(180deg);
                }
            </style>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200">
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold" style="width:40px;"></th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold" style="width:60px;">Row</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold">Data (JSON)</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold" style="width:90px;">Status</th>
                            <th class="text-left py-3 px-4 text-gray-500 font-semibold" style="width:180px;">Message</th>
                            <th class="text-center py-3 px-4 text-gray-500 font-semibold" style="width:80px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in previewRecords)
                        {
                            var rowColor = record.ValidationStatus == "Valid" ? "" :
                                           record.ValidationStatus == "Warning" ? "bg-yellow-50/40" :
                                           record.ValidationStatus == "Error" ? "bg-red-50/40" : "";
                            var statusBadge = record.ValidationStatus == "Valid" ? "text-green-600 bg-green-50" :
                                              record.ValidationStatus == "Warning" ? "text-yellow-600 bg-yellow-50" :
                                              record.ValidationStatus == "Error" ? "text-red-600 bg-red-50" : "text-gray-500 bg-gray-100";

                            var jsonData = new Dictionary<string, JsonElement>();
                            try { jsonData = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(record.RawData) ?? jsonData; } catch { }
                            var displayPairs = jsonData.Take(4);
                            var canEdit = record.ValidationStatus == "Warning" || record.ValidationStatus == "Error";
                            var prettyJson = JsonSerializer.Serialize(jsonData, new JsonSerializerOptions { WriteIndented = true });

                            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors @rowColor">
                                <td class="py-3 px-4 text-center align-top">
                                    <button type="button" onclick="toggleRow(this, @record.StagingRecordID)"
                                            class="text-gray-400 hover:text-gray-600 focus:outline-none" title="Expand row">
                                        <svg class="w-4 h-4 expand-icon" id="icon-@record.StagingRecordID" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path d="M19 9l-7 7-7-7" />
                                        </svg>
                                    </button>
                                </td>
                                <td class="py-3 px-4 text-gray-400 font-mono text-xs align-top">@record.RowNumber</td>
                                <td class="py-3 px-4 text-gray-600 text-xs">
                                    <div class="row-data-collapsed" id="data-@record.StagingRecordID">
                                        <div class="flex flex-wrap gap-1 mb-2">
                                            @foreach (var kvp in displayPairs)
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded bg-gray-100 text-xs">
                                                    <span class="font-semibold text-gray-700 mr-1">@kvp.Key:</span>
                                                    <span class="text-gray-500 truncate max-w-[120px]">@kvp.Value</span>
                                                </span>
                                            }
                                            @if (jsonData.Count > 4)
                                            {
                                                <span class="text-gray-400 text-xs">+@(jsonData.Count - 4) more</span>
                                            }
                                        </div>

        <div id="viewModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
            <div class="bg-white rounded-2xl shadow-xl p-8 max-w-2xl w-full mx-4 max-h-[80vh] overflow-y-auto">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-lg font-bold text-gray-900">View Record Data</h3>
                    <button type="button" onclick="closeViewModal()" class="text-gray-400 hover:text-gray-600">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                </div>
                <pre id="viewJsonArea" class="p-4 rounded-lg bg-gray-50 border border-gray-200 text-xs font-mono text-gray-700 whitespace-pre-wrap break-all"></pre>
            </div>
        </div>
                                        <pre class="mt-2 p-3 rounded-lg bg-gray-50 border border-gray-200 text-xs font-mono text-gray-700 whitespace-pre-wrap break-all">@prettyJson</pre>
                                    </div>
                                </td>
                                <td class="py-3 px-4 text-center align-top">
                                    <span class="text-xs font-medium px-2.5 py-1 rounded-full @statusBadge">@record.ValidationStatus</span>
                                </td>
                                <td class="py-3 px-4 text-xs text-gray-500 align-top break-words">@(record.ValidationMessage ?? "—")</td>
                                <td class="py-3 px-4 text-center align-top">
                                    @if (canEdit)
                                    {
                                        <button type="button" onclick="openEditModal(@record.StagingRecordID, @Html.Raw(System.Text.Json.JsonSerializer.Serialize(record.RawData)))"
                                                class="px-3 py-1 text-xs font-semibold rounded-lg text-amber-700 bg-amber-50 hover:bg-amber-100 transition-colors">
                                            Edit
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-gray-300">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex items-center justify-between">
            <a href="@Url.Action("StaffNav", "Staff", new { section = "upload" })"
               class="px-6 py-2.5 border border-gray-300 rounded-lg text-sm font-semibold text-gray-600 hover:bg-gray-50 transition-colors no-underline">
                &larr; Back to Upload
            </a>
            <a href="@Url.Action("StaffNav", "Staff", new { section = "submit" })"
               class="px-6 py-2.5 text-white rounded-lg text-sm font-semibold transition-colors no-underline" style="background-color: #088395;" onmouseover="this.style.backgroundColor='#09637E'" onmouseout="this.style.backgroundColor='#088395'">
                Continue to Submit &rarr;
            </a>
        </div>

        <!-- Edit Record Modal -->
        <div id="editModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
            <div class="bg-white rounded-2xl shadow-xl p-8 max-w-2xl w-full mx-4 max-h-[80vh] overflow-y-auto">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-lg font-bold text-gray-900">Correct Record Data</h3>
                    <button type="button" onclick="closeEditModal()" class="text-gray-400 hover:text-gray-600">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                </div>
                <p class="text-sm text-gray-500 mb-4">Edit the JSON data below to fix validation issues, then save. Re-validate the batch after correcting.</p>
                <form method="post" asp-action="CorrectRecord" asp-controller="Staff">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="recordId" id="editRecordId" />
                    <textarea name="correctedJson" id="editJsonArea" rows="12"
                              class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-300 resize-y"></textarea>
                    <div class="flex items-center justify-end gap-3 mt-4">
                        <button type="button" onclick="closeEditModal()" class="px-4 py-2 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-50">Cancel</button>
                        <button type="submit" class="px-4 py-2 text-white rounded-lg text-sm font-semibold" style="background-color: #088395;">Save Correction</button>
                    </div>
                </form>
            </div>
        </div>

        <script>
            function toggleRow(btn, recordId) {
                var dataEl = document.getElementById('data-' + recordId);
                var iconEl = document.getElementById('icon-' + recordId);
                if (dataEl.classList.contains('row-data-collapsed')) {
                    dataEl.classList.remove('row-data-collapsed');
                    dataEl.classList.add('row-data-expanded');
                    iconEl.classList.add('rotated');
                } else {
                    dataEl.classList.remove('row-data-expanded');
                    dataEl.classList.add('row-data-collapsed');
                    iconEl.classList.remove('rotated');
                }
            }
            function openEditModal(recordId, rawJson) {
                document.getElementById('editRecordId').value = recordId;
                try {
                    var parsed = JSON.parse(rawJson);
                    document.getElementById('editJsonArea').value = JSON.stringify(parsed, null, 2);
                } catch (e) {
                    document.getElementById('editJsonArea').value = rawJson;
                }
                var modal = document.getElementById('editModal');
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            }
            function closeEditModal() {
                var modal = document.getElementById('editModal');
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
            function openViewModal(recordId, rawJson) {
                try {
                    var parsed = JSON.parse(rawJson);
                    document.getElementById('viewJsonArea').textContent = JSON.stringify(parsed, null, 2);
                } catch (e) {
                    document.getElementById('viewJsonArea').textContent = rawJson;
                }
                var modal = document.getElementById('viewModal');
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            }
            function closeViewModal() {
                var modal = document.getElementById('viewModal');
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        </script>
    }
</div>
