{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "PayMongo": {
    "SecretKey": "<secret>",
    "PublicKey": "<public>"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "EmailSettings": {
    "Host": "smtp.gmail.com",
    "Port": "587",
    "Username": "<username>",
    "Password": "<password>",
    "FromEmail": "<from-email>",
    "FromName": "<from-name>",
    "UseSsl": "true"
  },
  "BackupSettings": {
    "BackupPath": "/private/Backup",
    "RetentionDays": "30"
  },
  "SeedSettings": {
    "SuperAdminEmail": "superadmin@example.com"
  },
  "ReCaptchaSettings": {
    "SiteKey": "<site-key>",
    "SecretKey": "<secret-key>",
    "VerifyUrl": "https://www.google.com/recaptcha/api/siteverify"
  },
  "SecuritySettings": {
    "SuperAdminLockdownCode": "CHANGE_ME"
  }
